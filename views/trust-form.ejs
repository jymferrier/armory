<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <div>
      <p class="breadcrumb"><a href="/trusts">← TRUSTS</a></p>
      <h1 class="page-title">ADD TRUST</h1>
    </div>
  </div>

  <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>

  <form method="POST" action="/trusts/new" class="firearm-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-band">
      <div class="form-band__label">TRUST INFO</div>
      <div class="form-band__fields">
        <div class="field-row">
          <div class="field">
            <label class="field-label">TRUST NAME <span class="required">*</span></label>
            <input type="text" name="name" class="field-input" required list="trustNameSuggestions"
              value="<%= typeof presetName !== 'undefined' ? presetName : '' %>"
              placeholder="e.g. Gunz Trust">
            <datalist id="trustNameSuggestions">
              <% suggestions.forEach(n => { %><option value="<%= n %>"><% }) %>
            </datalist>
          </div>
          <div class="field">
            <label class="field-label">SETTLOR NAME</label>
            <input type="text" name="settlor_name" class="field-input" placeholder="e.g. Bart Simpson">
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label class="field-label">SETTLOR LOCATION</label>
            <input type="text" name="settlor_location" class="field-input" placeholder="e.g. Springfield, Illinois">
          </div>
          <div class="field">
            <label class="field-label">TRUST AGREEMENT DATE</label>
            <input type="date" name="agreement_date" class="field-input field-input--date">
          </div>
        </div>
      </div>
    </div>
    <div class="form-actions">
      <a href="/trusts" class="btn btn--ghost">CANCEL</a>
      <button type="submit" class="btn btn--primary">CREATE TRUST</button>
    </div>
  </form>
</div>
<script nonce="<%= cspNonce %>">
  const urlName = new URLSearchParams(window.location.search).get('name');
  if (urlName) document.querySelector('[name="name"]').value = urlName;
</script>
<%- include('partials/footer') %>
