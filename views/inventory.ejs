<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">INVENTORY</h1>
      <p class="page-sub" id="inventoryCount"><%= firearms.length %> ITEM<%= firearms.length !== 1 ? 'S' : '' %> CATALOGUED</p>
    </div>
    <div class="page-actions">
      <form method="GET" action="/inventory" class="search-form">
        <input type="text" name="q" value="<%= q %>" placeholder="SEARCH INVENTORY…" class="search-input">
        <div class="type-dropdown" id="typeDropdown" style="display:none">
          <button type="button" class="type-dropdown__btn" id="typeDropdownBtn">ALL TYPES ▾</button>
          <div class="type-dropdown__panel" id="typeDropdownPanel"></div>
        </div>
        <button type="submit" class="btn btn--ghost">SEARCH</button>
        <% if (q) { %><a href="/inventory" class="btn btn--ghost">CLEAR</a><% } %>
      </form>
      <div class="view-toggle" id="viewToggle">
        <button type="button" class="view-toggle__btn" id="btnGrid" title="Grid view">⊞</button>
        <button type="button" class="view-toggle__btn" id="btnList" title="List view">≡</button>
      </div>
      <a href="/inventory/new" class="btn btn--primary">+ ADD FIREARM</a>
    </div>
  </div>

  <% if (firearms.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">⊘</div>
      <p class="empty-text"><%= q ? 'NO RESULTS FOR "' + q + '"' : 'NO ITEMS IN INVENTORY' %></p>
      <% if (!q) { %><a href="/inventory/new" class="btn btn--primary">ADD FIRST ITEM</a><% } %>
    </div>
  <% } else { %>

    <!-- Grid view -->
    <div id="viewGrid">
      <div class="inventory-grid">
        <% firearms.forEach(f => { %>
          <a href="/inventory/<%= f.id %>" class="firearm-card" data-type="<%= f.nfa_type || '' %>">
            <div class="firearm-card__photo">
              <% if (f.primary_photo) { %>
                <img src="/api/photo/<%= f.primary_photo.filename %>" alt="<%= f.manufacturer %> <%= f.model %>">
              <% } else { %>
                <div class="firearm-card__no-photo">NO PHOTO</div>
              <% } %>
            </div>
            <div class="firearm-card__body">
              <div class="firearm-card__badges">
                <% if (f.nfa_type) { %><span class="badge <%= f.is_nfa ? ((f.nfa_approve_date && (!f.nfa2_enabled || f.nfa2_approve_date)) ? 'badge--nfa-approved' : 'badge--nfa') : 'badge--type' %> badge--searchable" data-search="<%= f.nfa_type %>"><%= f.nfa_type %></span><% } %>
                <% if (f.caliber) { %><span class="badge badge--caliber badge--searchable" data-search="<%= f.caliber %>"><%= f.caliber %></span><% } %>
              </div>
              <h2 class="firearm-card__make"><%= f.manufacturer %></h2>
              <p class="firearm-card__model"><%= f.model %></p>
              <% if (f.serial) { %>
                <p class="firearm-card__serial">S/N: <%= f.serial %></p>
              <% } %>
              <% if (f.optics) {
                  let cardOptics = [];
                  try { const p = JSON.parse(f.optics); cardOptics = Array.isArray(p) ? p : [f.optics]; }
                  catch(e) { cardOptics = [f.optics]; }
                %>
                <p class="firearm-card__optics">⊕ <% cardOptics.forEach(function(o, i) { %><span class="badge--searchable" data-search="<%= o %>"><%= o %></span><% if (i < cardOptics.length - 1) { %>, <% } %><% }) %></p>
              <% } %>
            </div>
          </a>
        <% }) %>
      </div>
    </div>

    <!-- List view -->
    <div id="viewList">
      <div class="inventory-list">
        <% firearms.forEach(f => { %>
          <a href="/inventory/<%= f.id %>" class="firearm-row" data-type="<%= f.nfa_type || '' %>">
            <div class="firearm-row__thumb">
              <% if (f.primary_photo) { %>
                <img src="/api/photo/<%= f.primary_photo.filename %>" alt="">
              <% } else { %>
                <div class="firearm-row__no-photo">NO PHOTO</div>
              <% } %>
            </div>
            <div class="firearm-row__main">
              <div class="firearm-row__title"><%= f.manufacturer %> <span><%= f.model %></span></div>
              <div class="firearm-row__meta">
                <% if (f.serial) { %>S/N: <%= f.serial %><% } %>
                <% if (f.serial && (f.caliber || f.date_acquired)) { %> &middot; <% } %>
                <% if (f.caliber) { %><%= f.caliber %><% } %>
                <% if (f.caliber && f.date_acquired) { %> &middot; <% } %>
                <% if (f.date_acquired) { %>Acq: <%= f.date_acquired %><% } %>
              </div>
            </div>
            <div class="firearm-row__badges">
              <% if (f.is_nfa) { %><span class="badge <%= (f.nfa_approve_date && (!f.nfa2_enabled || f.nfa2_approve_date)) ? 'badge--nfa-approved' : 'badge--nfa' %> badge--searchable" data-search="<%= f.nfa_type %>"><%= f.nfa_type %></span><% } %>
              <% if (!f.is_nfa && f.nfa_type) { %><span class="badge badge--type badge--searchable" data-search="<%= f.nfa_type %>"><%= f.nfa_type %></span><% } %>
              <% if (f.is_disposed) { %><span class="badge badge--disposed badge--searchable" data-search="DISPOSED">DISPOSED</span><% } %>
            </div>
          </a>
        <% }) %>
      </div>
    </div>

  <% } %>
</div>

<script nonce="<%= cspNonce %>">
function setView(v) {
  document.getElementById('viewGrid').style.display = v === 'grid' ? '' : 'none';
  document.getElementById('viewList').style.display = v === 'list' ? '' : 'none';
  document.getElementById('btnGrid').classList.toggle('view-toggle__btn--active', v === 'grid');
  document.getElementById('btnList').classList.toggle('view-toggle__btn--active', v === 'list');
  try { localStorage.setItem('armory_inventory_view', v); } catch(e) {}
}
document.getElementById('btnGrid').addEventListener('click', function() { setView('grid'); });
document.getElementById('btnList').addEventListener('click', function() { setView('list'); });
(function() {
  var saved = 'grid';
  try { saved = localStorage.getItem('armory_inventory_view') || 'grid'; } catch(e) {}
  setView(saved);
})();
document.addEventListener('click', function(e) {
  var badge = e.target.closest('.badge--searchable');
  if (!badge) return;
  e.preventDefault();
  e.stopImmediatePropagation();
  window.location.href = '/inventory?q=' + encodeURIComponent(badge.getAttribute('data-search'));
}, true);

// ── Type filter dropdown ───────────────────────────────────
(function() {
  var NFA_TYPES = new Set(['Suppressor/Silencer','Short Barrel Rifle (SBR)','Short Barrel Shotgun (SBS)','Machine Gun','Destructive Device (DD)','Any Other Weapon (AOW)']);
  var gridCards = Array.from(document.querySelectorAll('.firearm-card[data-type]'));
  var listRows  = Array.from(document.querySelectorAll('.firearm-row[data-type]'));
  if (!gridCards.length) return;

  var typeSet = new Set(gridCards.map(function(c) { return c.dataset.type; }));
  var types = Array.from(typeSet).sort(function(a, b) {
    if (!a && b) return 1;
    if (a && !b) return -1;
    return a.localeCompare(b);
  });
  if (types.length <= 1) return;

  var dropdown  = document.getElementById('typeDropdown');
  var btn       = document.getElementById('typeDropdownBtn');
  var panel     = document.getElementById('typeDropdownPanel');
  var countEl   = document.getElementById('inventoryCount');
  var active    = new Set();
  var total     = gridCards.length;

  // Build checkbox list
  types.forEach(function(type) {
    var label = document.createElement('label');
    label.className = 'type-option';
    var cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.className = 'type-option__cb';
    cb.value = type;
    cb.addEventListener('change', function() {
      if (cb.checked) active.add(type); else active.delete(type);
      apply();
    });
    var text = document.createElement('span');
    text.className = 'type-option__label' + (NFA_TYPES.has(type) ? ' type-option__label--nfa' : '');
    text.textContent = type || 'UNCLASSIFIED';
    label.appendChild(cb);
    label.appendChild(text);
    panel.appendChild(label);
  });

  dropdown.style.display = '';

  // Toggle open/close
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    var open = panel.classList.toggle('type-dropdown__panel--open');
    btn.classList.toggle('type-dropdown__btn--open', open);
  });
  document.addEventListener('click', function(e) {
    if (!dropdown.contains(e.target)) {
      panel.classList.remove('type-dropdown__panel--open');
      btn.classList.remove('type-dropdown__btn--open');
    }
  });

  function apply() {
    // Update button label
    if (active.size === 0) {
      btn.textContent = 'ALL TYPES ▾';
      btn.classList.remove('type-dropdown__btn--active');
    } else {
      btn.textContent = active.size + ' TYPE' + (active.size !== 1 ? 'S' : '') + ' ▾';
      btn.classList.add('type-dropdown__btn--active');
    }

    // Filter items
    var visible = 0;
    gridCards.forEach(function(card, i) {
      var show = active.size === 0 || active.has(card.dataset.type);
      card.style.display = show ? '' : 'none';
      if (listRows[i]) listRows[i].style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // Update count
    if (countEl) {
      var label = active.size > 0
        ? visible + ' OF ' + total + ' ITEM' + (total !== 1 ? 'S' : '')
        : total + ' ITEM' + (total !== 1 ? 'S' : '');
      countEl.textContent = label + ' CATALOGUED';
    }
  }
})();
</script>
<%- include('partials/footer') %>
