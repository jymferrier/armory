<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Assignment to <%= trust.name %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Times New Roman', Times, serif;
      font-size: 12pt;
      color: #000;
      background: #d0d0d0;
      line-height: 1.6;
    }

    /* ── Screen chrome ──────────────────────────────────────────── */
    .screen-actions {
      background: #222;
      padding: 0.75rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .screen-actions a, .screen-actions button {
      font-family: 'Courier New', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      padding: 0.45rem 1rem;
      border: 1px solid #555;
      background: transparent;
      color: #ccc;
      cursor: pointer;
      text-decoration: none;
    }
    .screen-actions button.print-btn {
      background: #c8963c;
      border-color: #c8963c;
      color: #000;
      font-weight: bold;
    }
    .screen-note {
      font-family: 'Courier New', monospace;
      font-size: 0.68rem;
      color: #888;
      margin-left: auto;
    }

    /* ── Paper ──────────────────────────────────────────────────── */
    .paper {
      max-width: 8.5in;
      margin: 2rem auto;
      background: white;
      padding: 1in;
      box-shadow: 0 4px 30px rgba(0,0,0,0.4);
    }

    /* ── Document header ────────────────────────────────────────── */
    .doc-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.5rem;
      border-bottom: 2px solid #000;
      padding-bottom: 0.75rem;
    }
    .doc-header-trust {
      font-size: 9pt;
      font-style: italic;
      color: #444;
      text-align: right;
    }
    .doc-title {
      text-align: center;
      font-size: 14pt;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 0.25rem;
    }
    .doc-subtitle {
      text-align: center;
      font-size: 11pt;
      font-style: italic;
      margin-bottom: 1.5rem;
    }

    /* ── Date line ──────────────────────────────────────────────── */
    .doc-date-line {
      margin-bottom: 1.25rem;
    }
    .doc-date-line .blank {
      display: inline-block;
      border-bottom: 1px solid #000;
      min-width: 1.5in;
      vertical-align: bottom;
    }

    /* ── Intro ──────────────────────────────────────────────────── */
    .doc-intro {
      margin-bottom: 1.25rem;
      text-align: justify;
    }

    /* ── Table ──────────────────────────────────────────────────── */
    .doc-table {
      width: 100%;
      border-collapse: collapse;
      border: 1px solid #000;
      margin-bottom: 1.25rem;
      font-size: 10.5pt;
    }
    .doc-table th {
      border: 1px solid #000;
      padding: 0.3rem 0.4rem;
      font-weight: bold;
      text-align: center;
      background: #f2f2f2;
      font-size: 10pt;
      line-height: 1.3;
    }
    .doc-table th:last-child { border-right: 1px solid #000; }
    .doc-table td {
      border: 1px solid #000;
      padding: 0.35rem 0.4rem;
      text-align: left;
      vertical-align: middle;
      height: 1.5rem;
      line-height: 1.3;
    }
    .doc-table td:last-child { border-right: 1px solid #000; }
    .doc-table td.row-num {
      width: 0.28in;
      text-align: right;
      font-size: 9pt;
      color: #555;
      padding-right: 0.3rem;
    }
    .doc-table td.col-make   { width: 1.45in; }
    .doc-table td.col-model  { width: 1.2in; }
    .doc-table td.col-type   { width: 0.85in; }
    .doc-table td.col-cal    { width: 0.72in; }
    .doc-table td.col-serial { width: 1.35in; text-align: center; font-family: 'Courier New', monospace; font-size: 10pt; }
    .doc-table td.col-last   { width: 1.0in; font-size: 10pt; }
    .doc-table .sub-val {
      display: block;
      font-size: 9pt;
      color: #555;
      margin-top: 0.1rem;
    }

    /* ── Legal text ─────────────────────────────────────────────── */
    .doc-legal {
      font-size: 10.5pt;
      text-align: justify;
      margin-bottom: 1.25rem;
      line-height: 1.5;
    }

    /* ── Witness whereof ────────────────────────────────────────── */
    .doc-witness {
      margin-bottom: 1.5rem;
      text-align: justify;
    }

    /* ── Signature block ────────────────────────────────────────── */
    .sig-section {
      margin-bottom: 1.5rem;
    }
    .sig-row {
      display: flex;
      gap: 2.5rem;
      align-items: flex-end;
      margin-bottom: 0.5rem;
    }
    .sig-block {
      flex: 2;
    }
    .sig-block-date {
      flex: 1;
    }
    .sig-line {
      border-bottom: 1px solid #000;
      width: 100%;
      margin-bottom: 0.2rem;
      min-height: 1.8rem;
    }
    .sig-label {
      font-size: 10pt;
    }

    /* ── Notary ─────────────────────────────────────────────────── */
    .notary-section {
      border-top: 1px solid #bbb;
      padding-top: 0.75rem;
      margin-top: 0.5rem;
    }
    .notary-state {
      margin-bottom: 0.6rem;
      font-size: 11pt;
    }
    .notary-state-row {
      display: flex;
      align-items: flex-end;
      margin-bottom: 0.25rem;
    }
    .notary-state-row .label { white-space: nowrap; }
    .notary-state-row .blank {
      flex: 1;
      border-bottom: 1px solid #000;
      margin: 0 0.4rem;
      min-width: 1.75in;
    }
    .notary-state-row .paren { white-space: nowrap; font-size: 13pt; }
    .notary-body {
      font-size: 11pt;
      margin-bottom: 1rem;
      text-align: justify;
    }
    .notary-footer {
      display: flex;
      gap: 1.5rem;
      align-items: flex-start;
    }
    .notary-sig-col {
      flex: 1;
    }
    .notary-sig-col .sig-line { min-height: 2rem; margin-top: 0.5rem; }
    .stamp-box {
      width: 1.75in;
      height: 1.75in;
      flex-shrink: 0;
    }

    /* ── Footer ─────────────────────────────────────────────────── */
    .doc-footer {
      display: flex;
      justify-content: space-between;
      font-size: 9pt;
      color: #888;
      font-style: italic;
      margin-top: 1.5rem;
      padding-top: 0.4rem;
      border-top: 1px solid #ddd;
    }

    /* ── Print ──────────────────────────────────────────────────── */
    @media print {
      body { background: white; font-size: 10pt; line-height: 1.25; }
      .screen-actions { display: none; }
      .paper {
        margin: 0;
        box-shadow: none;
        max-width: none;
        padding: 0;
        page-break-after: always;
        display: flex;
        flex-direction: column;
        height: 9.7in;
      }
      .paper:last-child { page-break-after: avoid; }
      .doc-bottom { margin-top: auto; }

      /* Tighten spacing */
      .doc-title       { font-size: 12pt; margin-bottom: 0.1rem; }
      .doc-subtitle    { font-size: 9.5pt; margin-bottom: 0.4rem; }
      .doc-date-line   { margin-bottom: 0.35rem; font-size: 10pt; }
      .doc-intro       { margin-bottom: 0.35rem; font-size: 10pt; }
      .doc-table       { margin-bottom: 0.35rem; font-size: 9.5pt; border: 1px solid #000; }
      .doc-table th    { padding: 0.15rem 0.3rem; font-size: 9pt; }
      .doc-table td    { padding: 0.15rem 0.3rem; height: 1rem; font-size: 9.5pt; }
      .doc-legal       { font-size: 9.5pt; margin-bottom: 0.35rem; line-height: 1.25; }
      .doc-witness     { margin-bottom: 0.35rem; font-size: 10pt; }
      .sig-section     { margin-bottom: 0.2rem; }
      .sig-line        { min-height: 0.7rem; }
      .notary-section  { padding-top: 0.35rem; margin-top: 0.15rem; }
      .notary-state    { margin-bottom: 0.25rem; font-size: 10pt; }
      .notary-state-row { margin-bottom: 0.1rem; }
      .notary-body     { font-size: 10pt; margin-bottom: 0.35rem; }
      .notary-sig-col .sig-line { margin-top: 0.25rem; }
      .stamp-box       { width: 2.25in; height: 2.25in; }
      .doc-footer      { margin-top: 0.3rem; padding-top: 0.15rem; }
      .doc-header      { margin-bottom: 0.4rem; padding-bottom: 0.25rem; }

      @page { margin: 0.65in; size: letter portrait; }
    }
  </style>
</head>
<body>

<% if (!locals.pdfMode) { %>
<div class="screen-actions">
  <button class="print-btn" id="printBtn">&#9113; PRINT</button>
  <a href="/trusts/<%= trust.id %>">&#8592; BACK TO TRUST</a>
</div>
<% } %>

<%
  const trustNameUpper = trust.name.toUpperCase();
  const settlor        = (trust.settlor_name || '').toUpperCase();
  const location       = trust.settlor_location || '';

  let agreementDateStr = '';
  if (trust.agreement_date) {
    const d = new Date(trust.agreement_date + 'T00:00:00');
    agreementDateStr = d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function blank(min) {
    return '<span class="blank" style="min-width:' + (min||'1.5in') + '"></span>';
  }

  const ITEMS_PER_PAGE = 5;
  const MIN_ROWS       = 5;

  const pages = [];
  if (items.length === 0) {
    pages.push([]);
  } else {
    for (let i = 0; i < items.length; i += ITEMS_PER_PAGE) {
      pages.push(items.slice(i, i + ITEMS_PER_PAGE));
    }
  }
%>

<% pages.forEach(function(pageItems, pageIdx) {
     const rowOffset = pageIdx * ITEMS_PER_PAGE;
     const rowCount  = Math.max(pageItems.length, MIN_ROWS);
%>
<div class="paper">

  <div class="doc-title">Assignment of Property</div>
  <div class="doc-subtitle">to the <%= trust.name %></div>

  <p class="doc-date-line">
    This Assignment is made and entered into as of <%- blank('2in') %>, 20<span class="blank" style="min-width:0.4in"></span>.
  </p>

  <p class="doc-intro">
    Know all persons by these presents that <strong><%= settlor || 'I' %></strong><% if (location) { %>, of <strong><%= location %></strong><% } %>,
    as Settlor and Trustee of the <strong><%= trustNameUpper %></strong><% if (agreementDateStr) { %>,
    established pursuant to that certain Trust Agreement dated <strong><%= agreementDateStr %></strong><% } %>,
    do hereby <strong>GRANT, BARGAIN, SELL, TRANSFER, and ASSIGN</strong> unto the
    <strong><%= trustNameUpper %></strong> the following described property,
    to be held by the Trust in accordance with the terms thereof:
  </p>

  <table class="doc-table">
    <thead>
      <tr>
        <th></th>
        <th>Manufacturer</th>
        <th>Model</th>
        <th>Type</th>
        <th>Caliber /<br>Gauge</th>
        <th>Serial Number</th>
        <th>NFA Approved /<br>Acquired From</th>
      </tr>
    </thead>
    <tbody>
      <% for (let i = 0; i < rowCount; i++) {
           const item      = pageItems[i] || null;
           const globalNum = i + 1;

           let approveDate = '';
           if (item && item.nfa_approve_date) {
             const d = new Date(item.nfa_approve_date + 'T00:00:00');
             approveDate = d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
           }
           const acquiredFrom = item ? (item.acquired_from || '') : '';
      %>
      <tr>
        <td class="row-num"><%= globalNum %>.</td>
        <td class="col-make"><%= item ? item.manufacturer : '' %></td>
        <td class="col-model"><%= item ? item.model : '' %></td>
        <td class="col-type"><%= item ? (item.nfa_type || '') : '' %></td>
        <td class="col-cal"><%= item ? (item.caliber || '') : '' %></td>
        <td class="col-serial"><%= item ? (item.serial || '') : '' %></td>
        <td class="col-last">
          <%= approveDate %>
          <% if (acquiredFrom) { %><span class="sub-val"><%= acquiredFrom %></span><% } %>
        </td>
      </tr>
      <% } %>
    </tbody>
  </table>

  <p class="doc-legal">
    The Assignor represents and warrants that the above-described property is owned free
    and clear of all liens and encumbrances, and that Assignor has full right, title,
    and authority to make this assignment. This assignment is subject to all applicable
    federal, state, and local laws and regulations, including without limitation the
    National Firearms Act (26 U.S.C. &sect;&nbsp;5801 <em>et seq.</em>) and the Gun
    Control Act (18 U.S.C. &sect;&nbsp;921 <em>et seq.</em>). In the event this
    assignment would violate any such law or regulation, the assignment of that item
    shall be void and of no force or effect.
  </p>

  <p class="doc-witness">
    <strong>IN WITNESS WHEREOF</strong>, the undersigned has executed this Assignment
    as of the date first written above.
  </p>

  <div class="doc-bottom">
    <div class="sig-section">
      <div class="sig-row">
        <div class="sig-block">
          <div class="sig-line"></div>
          <div class="sig-label"><%= settlor || 'Settlor and Trustee' %><% if (settlor) { %>, Settlor and Trustee<% } %></div>
        </div>
        <div class="sig-block-date">
          <div class="sig-line"></div>
          <div class="sig-label">Date</div>
        </div>
      </div>
    </div>

    <div class="notary-section">
      <div class="notary-state">
        <div class="notary-state-row">
          <span class="label">State of</span>
          <span class="blank"></span>
          <span class="paren">)</span>
        </div>
        <div class="notary-state-row">
          <span class="label" style="padding-left:0.75in">&nbsp;</span>
          <span style="white-space:nowrap; font-size:9pt; padding: 0 0.5rem; padding-bottom:0.1rem">)</span>
          <span style="white-space:nowrap; font-size:9.5pt; font-style:italic">ss.</span>
        </div>
        <div class="notary-state-row">
          <span class="label">County of</span>
          <span class="blank"></span>
          <span class="paren">)</span>
        </div>
      </div>

      <p class="notary-body">
        This instrument was acknowledged before me on the <span class="blank" style="min-width:0.3in"></span> day
        of <span class="blank" style="min-width:1in"></span>, 20<span class="blank" style="min-width:0.4in"></span>,
        by <strong><%= settlor || '_______________' %></strong>, as Settlor and Trustee of the <strong><%= trustNameUpper %></strong>.
      </p>

      <div class="notary-footer">
        <div class="notary-sig-col">
          <div class="sig-line"></div>
          <div class="sig-label">Signature of Notarial Officer</div>
          <div class="sig-label" style="margin-top:0.25rem">Printed Name: <span class="blank" style="min-width:1.5in"></span></div>
          <div class="sig-label" style="margin-top:0.25rem">My Commission Expires: <span class="blank" style="min-width:1.1in"></span></div>
        </div>
        <div class="stamp-box"></div>
      </div>
    </div>

    <div class="doc-footer">
      <span>Assignment of Property &mdash; <%= trust.name %></span>
      <span>Executed under penalty of law &mdash; retain with trust records</span>
    </div>
  </div>

</div>
<% }); %>

<script nonce="<%= cspNonce %>">
document.getElementById('printBtn').addEventListener('click', function() { window.print(); });
</script>
</body>
</html>
