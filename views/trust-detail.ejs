<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <div>
      <p class="breadcrumb"><a href="/trusts">← TRUSTS</a></p>
      <h1 class="page-title"><%= trust.name.toUpperCase() %></h1>
    </div>
    <div class="page-actions">
      <form method="POST" action="/trusts/<%= trust.id %>/delete" onsubmit="return confirm('Delete this trust?')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn--danger btn--sm">DELETE TRUST</button>
      </form>
    </div>
  </div>

  <% if (saved) { %>
  <div class="alert alert--success">Trust details saved.</div>
  <% } %>
  <% if (locals.detailsRequired) { %>
  <div class="alert alert--error">Cannot generate assignment sheet — please fill in the following fields first: <strong><%= detailsRequired %></strong></div>
  <% } %>

  <!-- Trust metadata -->
  <form method="POST" action="/trusts/<%= trust.id %>" class="firearm-form" style="margin-bottom:2px;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-band">
      <div class="form-band__label">TRUST DETAILS</div>
      <div class="form-band__fields">
        <div class="field-row">
          <div class="field">
            <label class="field-label">SETTLOR NAME</label>
            <input type="text" name="settlor_name" class="field-input" value="<%= trust.settlor_name || '' %>" placeholder="e.g. Bart Simpson">
          </div>
          <div class="field">
            <label class="field-label">SETTLOR LOCATION</label>
            <input type="text" name="settlor_location" class="field-input" value="<%= trust.settlor_location || '' %>" placeholder="e.g. Springfield, Illinois">
          </div>
        </div>
        <div class="field-row field-row--half">
          <div class="field">
            <label class="field-label">TRUST AGREEMENT DATE</label>
            <input type="date" name="agreement_date" class="field-input field-input--date" value="<%= trust.agreement_date || '' %>">
          </div>
        </div>
        <div class="form-actions" style="padding-top:0.75rem;">
          <button type="submit" class="btn btn--primary btn--sm">SAVE DETAILS</button>
        </div>
      </div>
    </div>
  </form>

  <!-- Items selection -->
  <div class="form-band" style="border-top:none;">
    <div class="form-band__label">ASSIGNED ITEMS</div>
    <div class="form-band__fields">
      <% if (items.length === 0) { %>
        <p style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted);">
          No items assigned to "<%= trust.name %>". Set the Trust / Entity Name on any firearm to assign it here.
        </p>
      <% } else { %>
        <p style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-dim);margin-bottom:1rem;letter-spacing:0.08em;">
          SELECT ITEMS TO INCLUDE IN THE ASSIGNMENT DOCUMENT
        </p>
        <% items.forEach(item => { %>
        <label class="trust-item-row" style="display:flex;align-items:center;gap:1rem;padding:0.65rem 0.75rem;border:1px solid var(--border);margin-bottom:3px;background:var(--bg-3);cursor:pointer;">
          <input type="checkbox" class="item-checkbox" value="<%= item.id %>" checked style="width:16px;height:16px;flex-shrink:0;accent-color:var(--accent);">
          <div style="flex:1;min-width:0;">
            <div style="font-family:var(--font-display);font-size:1.1rem;letter-spacing:0.05em;"><%= item.manufacturer %> <span style="color:var(--accent)"><%= item.model %></span></div>
            <div style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-muted);margin-top:0.1rem;">
              <% if (item.nfa_type) { %><span style="color:var(--nfa-red)"><%= item.nfa_type %></span><% } %>
              <% if (item.serial) { %> · S/N: <%= item.serial %><% } %>
              <% if (item.date_acquired) { %> · Acquired: <%= item.date_acquired %><% } %>
            </div>
          </div>
        </label>
        <% }) %>

        <div style="margin-top:1.25rem;display:flex;gap:0.75rem;align-items:center;">
          <button type="button" id="generateBtn" class="btn btn--primary" onclick="generateAssignment()">GENERATE ASSIGNMENT DOCUMENT</button>
          <button type="button" class="btn btn--ghost btn--sm" onclick="toggleAll(true)">SELECT ALL</button>
          <button type="button" class="btn btn--ghost btn--sm" onclick="toggleAll(false)">DESELECT ALL</button>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script nonce="<%= cspNonce %>">
function generateAssignment() {
  const missing = [];
  <% if (!trust.settlor_name) { %>missing.push('Settlor Name');<% } %>
  <% if (!trust.settlor_location) { %>missing.push('Settlor Location');<% } %>
  <% if (!trust.agreement_date) { %>missing.push('Trust Agreement Date');<% } %>
  if (missing.length > 0) {
    alert('Please fill in the following trust details before generating:\n\n• ' + missing.join('\n• '));
    return;
  }
  const checked = Array.from(document.querySelectorAll('.item-checkbox:checked')).map(cb => cb.value);
  if (checked.length === 0) { alert('Select at least one item.'); return; }
  const url = '/trusts/<%= trust.id %>/assignment?' + checked.map(id => 'items=' + id).join('&');
  window.open(url, '_blank');
}
function toggleAll(state) {
  document.querySelectorAll('.item-checkbox').forEach(cb => cb.checked = state);
}
</script>
<%- include('partials/footer') %>
