<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <div>
      <p class="breadcrumb"><a href="/trusts">← TRUSTS</a></p>
      <h1 class="page-title"><%= trust.name.toUpperCase() %></h1>
    </div>
    <div class="page-actions">
      <form method="POST" action="/trusts/<%= trust.id %>/delete" id="deleteTrustForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn--danger btn--sm">DELETE TRUST</button>
      </form>
    </div>
  </div>

  <% if (saved) { %>
  <div class="alert alert--success">Trust details saved.</div>
  <% } %>
  <% if (locals.detailsRequired) { %>
  <div class="alert alert--error">Cannot generate assignment sheet — please fill in the following fields first: <strong><%= detailsRequired %></strong></div>
  <% } %>

  <!-- Trust metadata -->
  <form method="POST" action="/trusts/<%= trust.id %>" class="firearm-form" style="margin-bottom:2px;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-band">
      <div class="form-band__label">TRUST DETAILS</div>
      <div class="form-band__fields">
        <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1rem;line-height:1.5;">
          ⚠ Settlor Name, Settlor Location, and Trust Agreement Date must all be completed before an assignment sheet can be generated.
        </p>
        <div class="field-row">
          <div class="field">
            <label class="field-label">SETTLOR NAME</label>
            <input type="text" name="settlor_name" class="field-input" value="<%= trust.settlor_name || '' %>" placeholder="e.g. Bart Simpson">
          </div>
          <div class="field">
            <label class="field-label">SETTLOR LOCATION</label>
            <input type="text" name="settlor_location" class="field-input" value="<%= trust.settlor_location || '' %>" placeholder="e.g. Springfield, Illinois">
          </div>
        </div>
        <div class="field-row field-row--half">
          <div class="field">
            <label class="field-label">TRUST AGREEMENT DATE</label>
            <input type="date" name="agreement_date" class="field-input field-input--date" value="<%= trust.agreement_date || '' %>">
          </div>
        </div>
        <div class="field">
          <label class="field-label">NOTES</label>
          <textarea name="notes" class="field-textarea" rows="3" placeholder="Any notes about this trust…"><%= trust.notes || '' %></textarea>
        </div>
        <div class="form-actions" style="padding-top:0.75rem;">
          <button type="submit" class="btn btn--primary btn--sm">SAVE DETAILS</button>
        </div>
      </div>
    </div>
  </form>

  <!-- Trust Copy (single primary document) -->
  <div class="form-band" style="border-top:none;">
    <div class="form-band__label">TRUST COPY</div>
    <div class="form-band__fields">
      <% if (locals.docError) { %>
        <div class="alert alert--error" style="margin-bottom:1rem;"><%= docError %></div>
      <% } %>
      <% if (trust.trust_doc) { %>
        <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem 0.75rem;border:1px solid var(--border);margin-bottom:1rem;background:var(--bg-3);">
          <span style="font-family:var(--font-mono);font-size:0.78rem;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
            <%= trust.trust_doc.original_name || trust.trust_doc.filename %>
          </span>
          <a href="/api/trust-document/<%= trust.trust_doc.filename %>" class="btn btn--ghost btn--sm">↓ DOWNLOAD</a>
          <% if (!user.is_spouse_view) { %>
          <form method="POST" action="/trusts/<%= trust.id %>/documents/<%= trust.trust_doc.id %>/delete" class="trust-doc-delete-form" data-name="<%= trust.trust_doc.original_name || trust.trust_doc.filename %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn--danger btn--sm">REMOVE</button>
          </form>
          <% } %>
        </div>
      <% } else { %>
        <p style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted);margin-bottom:1rem;">No trust copy on file.</p>
      <% } %>
      <% if (!user.is_spouse_view) { %>
      <form method="POST" action="/trusts/<%= trust.id %>/trust-document" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field">
          <label class="field-label"><%= trust.trust_doc ? 'REPLACE TRUST COPY' : 'UPLOAD TRUST COPY' %></label>
          <input type="file" name="trust_doc" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" class="file-input-plain" required>
          <p style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-muted);margin-top:0.4rem;">PDF, images, or Word documents · Max 50 MB</p>
        </div>
        <button type="submit" class="btn btn--primary btn--sm">↑ <%= trust.trust_doc ? 'REPLACE' : 'UPLOAD' %></button>
      </form>
      <% } %>
    </div>
  </div>

  <!-- Additional Documents -->
  <div class="form-band" style="border-top:none;">
    <div class="form-band__label">ADDITIONAL DOCUMENTS</div>
    <div class="form-band__fields">
      <% if (trust.additional_docs && trust.additional_docs.length > 0) { %>
        <div style="margin-bottom:1.25rem;">
          <% trust.additional_docs.forEach(doc => { %>
            <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem 0.75rem;border:1px solid var(--border);margin-bottom:3px;background:var(--bg-3);">
              <span style="font-family:var(--font-mono);font-size:0.78rem;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= doc.original_name || doc.filename %></span>
              <a href="/api/trust-document/<%= doc.filename %>" class="btn btn--ghost btn--sm">↓ DOWNLOAD</a>
              <% if (!user.is_spouse_view) { %>
              <form method="POST" action="/trusts/<%= trust.id %>/documents/<%= doc.id %>/delete" class="trust-doc-delete-form" data-name="<%= doc.original_name || doc.filename %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn--danger btn--sm">DELETE</button>
              </form>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted);margin-bottom:1.25rem;">No additional documents attached.</p>
      <% } %>
      <% if (!user.is_spouse_view) { %>
      <form method="POST" action="/trusts/<%= trust.id %>/documents" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field">
          <label class="field-label">ATTACH DOCUMENT</label>
          <input type="file" name="trust_doc" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" class="file-input-plain" required>
          <p style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-muted);margin-top:0.4rem;">PDF, images, or Word documents · Max 50 MB</p>
        </div>
        <button type="submit" class="btn btn--primary btn--sm">↑ UPLOAD DOCUMENT</button>
      </form>
      <% } %>
    </div>
  </div>

  <!-- Items selection -->
  <div class="form-band" style="border-top:none;">
    <div class="form-band__label">ASSIGNED ITEMS</div>
    <div class="form-band__fields">
      <% if (items.length === 0) { %>
        <p style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted);">
          No items assigned to "<%= trust.name %>". Set the Trust / Entity Name on any firearm to assign it here.
        </p>
      <% } else { %>
        <p style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-dim);margin-bottom:1rem;letter-spacing:0.08em;">
          SELECT ITEMS TO INCLUDE IN THE ASSIGNMENT DOCUMENT · ITEMS MUST HAVE AN NFA APPROVED DATE AND NOT BE ALREADY ASSIGNED
        </p>
        <% items.forEach(item => {
             const fullyApproved = item.nfa_approve_date && (!item.nfa2_enabled || item.nfa2_approve_date);
             const notEligible = item.trust_assigned || !fullyApproved;
        %>
        <div style="display:flex;align-items:center;gap:1rem;padding:0.65rem 0.75rem;border:1px solid var(--border);margin-bottom:3px;background:var(--bg-3);<%= notEligible ? 'opacity:0.6;' : '' %>">
          <input type="checkbox" class="item-checkbox" value="<%= item.id %>"
            <%= notEligible ? 'disabled' : 'checked' %>
            style="width:16px;height:16px;flex-shrink:0;accent-color:var(--accent);">
          <% if (item.primary_photo) { %>
            <img src="/api/photo/<%= item.primary_photo.filename %>" alt=""
              style="width:48px;height:48px;object-fit:cover;flex-shrink:0;border:1px solid var(--border);">
          <% } else { %>
            <div style="width:48px;height:48px;flex-shrink:0;border:1px solid var(--border);background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:0.55rem;font-family:var(--font-mono);color:var(--text-dim);letter-spacing:0.05em;">NO<br>PHOTO</div>
          <% } %>
          <div style="flex:1;min-width:0;">
            <div style="font-family:var(--font-display);font-size:1.1rem;letter-spacing:0.05em;">
              <%= item.manufacturer %> <span style="color:var(--accent)"><%= item.model %></span>
              <% if (item.trust_assigned) { %>
                <span style="font-family:var(--font-mono);font-size:0.6rem;color:var(--nfa-green);border:1px solid var(--nfa-green);padding:0.1rem 0.4rem;margin-left:0.5rem;letter-spacing:0.1em;">ASSIGNED</span>
              <% } else if (!fullyApproved) { %>
                <span style="font-family:var(--font-mono);font-size:0.6rem;color:var(--nfa-red,#c0392b);border:1px solid var(--nfa-red,#c0392b);padding:0.1rem 0.4rem;margin-left:0.5rem;letter-spacing:0.1em;">PENDING APPROVAL</span>
              <% } %>
            </div>
            <div style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-muted);margin-top:0.1rem;">
              <% if (item.nfa_type) { %><span style="color:<%= fullyApproved ? 'var(--nfa-green)' : 'var(--nfa-red)' %>"><%= item.nfa_type %></span><% } %>
              <% if (item.serial) { %> · S/N: <%= item.serial %><% } %>
              <% if (item.nfa_approve_date) { %> · Approved: <%= item.nfa_approve_date %><% } else if (item.date_acquired) { %> · Acquired: <%= item.date_acquired %><% } %>
            </div>
          </div>
          <% if (!user.is_spouse_view) { %>
          <form method="POST" action="/trusts/<%= trust.id %>/firearms/<%= item.id %>/assign" style="flex-shrink:0;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn--ghost btn--sm" style="<%= item.trust_assigned ? 'color:var(--nfa-green);border-color:var(--nfa-green);' : '' %>">
              <%= item.trust_assigned ? 'UNASSIGN' : 'MARK ASSIGNED' %>
            </button>
          </form>
          <% } %>
        </div>
        <% }) %>

        <div style="margin-top:1.25rem;display:flex;gap:0.75rem;align-items:center;">
          <button type="button" id="generateBtn" class="btn btn--primary">GENERATE ASSIGNMENT DOCUMENT</button>
          <button type="button" id="selectAllBtn" class="btn btn--ghost btn--sm">SELECT ALL</button>
          <button type="button" id="deselectAllBtn" class="btn btn--ghost btn--sm">DESELECT ALL</button>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script nonce="<%= cspNonce %>">
document.addEventListener('DOMContentLoaded', function() {
  var deleteForm = document.getElementById('deleteTrustForm');
  if (deleteForm) {
    deleteForm.addEventListener('submit', function(e) {
      if (!confirm('Delete this trust?')) e.preventDefault();
    });
  }

  document.querySelectorAll('.trust-doc-delete-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      var name = this.getAttribute('data-name');
      if (!confirm('Delete document "' + name + '"?')) e.preventDefault();
    });
  });

  // Disable the generate button until all three trust detail fields are filled
  var settlorNameInput    = document.querySelector('[name="settlor_name"]');
  var settlorLocationInput = document.querySelector('[name="settlor_location"]');
  var agreementDateInput  = document.querySelector('[name="agreement_date"]');
  var generateBtn = document.getElementById('generateBtn');

  function updateGenerateBtn() {
    if (!generateBtn) return;
    var ready = settlorNameInput    && settlorNameInput.value.trim()
             && settlorLocationInput && settlorLocationInput.value.trim()
             && agreementDateInput  && agreementDateInput.value;
    generateBtn.disabled = !ready;
    generateBtn.title = ready ? '' : 'Complete all Trust Details fields above before generating';
  }

  [settlorNameInput, settlorLocationInput, agreementDateInput].forEach(function(el) {
    if (el) el.addEventListener('input', updateGenerateBtn);
  });
  updateGenerateBtn();

  if (generateBtn) {
    generateBtn.addEventListener('click', function() {
      var checked = Array.from(document.querySelectorAll('.item-checkbox:checked')).map(function(cb) { return cb.value; });
      if (checked.length === 0) { alert('Select at least one item.'); return; }
      var url = '/trusts/<%= trust.id %>/assignment?' + checked.map(function(id) { return 'items=' + id; }).join('&');
      window.open(url, '_blank');
    });
  }

  var selectAllBtn = document.getElementById('selectAllBtn');
  if (selectAllBtn) {
    selectAllBtn.addEventListener('click', function() {
      document.querySelectorAll('.item-checkbox:not([disabled])').forEach(function(cb) { cb.checked = true; });
    });
  }

  var deselectAllBtn = document.getElementById('deselectAllBtn');
  if (deselectAllBtn) {
    deselectAllBtn.addEventListener('click', function() {
      document.querySelectorAll('.item-checkbox:not([disabled])').forEach(function(cb) { cb.checked = false; });
    });
  }
});
</script>
<%- include('partials/footer') %>
