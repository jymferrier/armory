<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <div>
      <p class="breadcrumb"><a href="<%= firearm ? '/inventory/' + firearm.id : '/inventory' %>">← <%= firearm ? firearm.manufacturer + ' ' + firearm.model : 'INVENTORY' %></a></p>
      <h1 class="page-title"><%= firearm ? 'EDIT FIREARM' : 'ADD FIREARM' %></h1>
    </div>
  </div>

  <% if (error) { %>
    <div class="alert alert--error"><%= error %></div>
  <% } %>

  <form method="POST" action="/inventory/<%= firearm ? firearm.id + '/edit' : 'new' %>?_csrf=<%= csrfToken %>"
    <% if (!firearm) { %>enctype="multipart/form-data"<% } %>
    class="firearm-form">

    <!-- 01: IDENTIFICATION -->
    <div class="form-band">
      <div class="form-band__label">01 / IDENTIFICATION</div>
      <div class="form-band__fields">

        <div class="field field--checkbox">
          <label class="checkbox-label">
            <input type="checkbox" name="is_3d_printed" id="is3dPrinted" value="1" class="checkbox-input"
              <%= firearm && firearm.is_3d_printed ? 'checked' : '' %>>
            <span class="checkbox-custom"></span>
            <span class="checkbox-text">3D PRINTED / DIY</span>
          </label>
        </div>

        <div class="field-row">
          <div class="field">
            <label class="field-label"><span id="manufacturerLabelText">MANUFACTURER</span> <span class="required">*</span></label>
            <input type="text" name="manufacturer" class="field-input" list="manufacturerList" value="<%= firearm ? firearm.manufacturer : '' %>" required placeholder="e.g. Beretta" autocomplete="off">
            <datalist id="manufacturerList">
              <% manufacturers.forEach(m => { %><option value="<%= m %>"><% }) %>
            </datalist>
          </div>
          <div class="field">
            <label class="field-label">MODEL <span class="required">*</span></label>
            <input type="text" name="model" class="field-input" list="modelList" value="<%= firearm ? firearm.model : '' %>" required placeholder="e.g. 92FS" autocomplete="off">
            <datalist id="modelList">
              <% models.forEach(m => { %><option value="<%= m %>"><% }) %>
            </datalist>
          </div>
        </div>

        <div class="field-row field-row--half">
          <div class="field">
            <label class="field-label">MODEL NUMBER</label>
            <input type="text" name="model_number" class="field-input mono" value="<%= firearm ? (firearm.model_number || '') : '' %>" placeholder="e.g. JS92F300">
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label class="field-label">CALIBER</label>
            <input type="text" name="caliber" class="field-input" list="caliberList" value="<%= firearm ? (firearm.caliber || '') : '' %>" placeholder="e.g. 9mm, .308 Win, .223 Rem" autocomplete="off">
            <datalist id="caliberList">
              <% calibers.forEach(c => { %><option value="<%= c %>"><% }) %>
            </datalist>
          </div>
          <div class="field">
            <label class="field-label">SERIAL NUMBER</label>
            <input type="text" name="serial" class="field-input mono" value="<%= firearm ? (firearm.serial || '') : '' %>" placeholder="Manufacturer serial number">
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label class="field-label" id="barrelLengthLabel"><%= (firearm && firearm.nfa_type === 'Suppressor/Silencer') ? 'LENGTH' : 'BARREL LENGTH' %></label>
            <input type="text" name="barrel_length" class="field-input" list="barrelLengthList" value="<%= firearm ? (firearm.barrel_length || '') : '' %>" placeholder='e.g. 16", 18.5", 4.25"' autocomplete="off">
            <datalist id="barrelLengthList">
              <% barrelLengths.forEach(b => { %><option value="<%= b %>"><% }) %>
            </datalist>
          </div>
          <div class="field">
            <label class="field-label">OPTICS / ACCESSORIES</label>
            <%
              let initialOpticsTags = [];
              if (firearm && firearm.optics) {
                try {
                  const p = JSON.parse(firearm.optics);
                  initialOpticsTags = Array.isArray(p) ? p : [firearm.optics];
                } catch(e) { initialOpticsTags = [firearm.optics]; }
              }
            %>
            <input type="hidden" name="optics" id="opticsHidden" value="<%= JSON.stringify(initialOpticsTags) %>">
            <datalist id="opticsTagList">
              <% opticsTags.forEach(t => { %><option value="<%= t %>"><% }) %>
            </datalist>
            <div class="tag-input-container" id="opticsTagContainer">
              <input type="text" class="tag-input-field" id="opticsTagInput" list="opticsTagList" placeholder='e.g. X300, XPS3, "Vortex Razor HD Gen III"' autocomplete="off">
            </div>
          </div>
        </div>

        <% const showOverallLength = firearm && (firearm.nfa_type === 'Short Barrel Rifle (SBR)' || firearm.nfa_type === 'Short Barrel Shotgun (SBS)'); %>
        <div id="overallLengthRow" style="display:<%= showOverallLength ? '' : 'none' %>">
          <div class="field-row field-row--half">
            <div class="field">
              <label class="field-label">OVERALL LENGTH</label>
              <input type="text" name="overall_length" class="field-input" value="<%= firearm ? (firearm.overall_length || '') : '' %>" placeholder='e.g. 26.5", 30"'>
            </div>
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label class="field-label">ITEM TYPE</label>
            <%
              const allItemTypes = [
                { group: 'Standard', items: ['Handgun', 'Rifle', 'Shotgun'] },
                { group: 'NFA', items: ['Suppressor/Silencer','Short Barrel Rifle (SBR)','Short Barrel Shotgun (SBS)','Machine Gun','Destructive Device (DD)','Any Other Weapon (AOW)'] }
              ];
              const currentType = firearm ? (firearm.nfa_type || '') : '';
            %>
            <select name="item_type" id="itemType" class="field-select">
              <option value="">— SELECT TYPE —</option>
              <% allItemTypes.forEach(group => { %>
                <optgroup label="<%= group.group %>">
                  <% group.items.forEach(t => { %>
                    <option value="<%= t %>" <%= currentType === t ? 'selected' : '' %>><%= t %></option>
                  <% }) %>
                </optgroup>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="field-row field-row--half">
          <div class="field">
            <label class="field-label">TRUST / ENTITY NAME</label>
            <input type="text" name="nfa_trust_name" class="field-input"
              value="<%= firearm ? (firearm.nfa_trust_name || '') : '' %>"
              placeholder="Trust or entity name, if applicable">
          </div>
        </div>

      </div>
    </div>

    <!-- 02: ACQUISITION -->
    <div class="form-band">
      <div class="form-band__label">02 / ACQUISITION</div>
      <div class="form-band__fields">

        <div class="field-row">
          <div class="field">
            <label class="field-label">ACQUIRED DATE</label>
            <input type="date" name="date_acquired" class="field-input field-input--date" value="<%= firearm ? (firearm.date_acquired || '') : '' %>">
          </div>
          <div class="field">
            <label class="field-label">ACQUIRED FROM</label>
            <input type="text" name="acquired_from" class="field-input" list="acquiredFromList" value="<%= firearm ? (firearm.acquired_from || '') : '' %>" placeholder="e.g. GunBroker, Private sale, FFL dealer" autocomplete="off">
            <datalist id="acquiredFromList">
              <% acquiredFromList.forEach(a => { %><option value="<%= a %>"><% }) %>
            </datalist>
          </div>
        </div>

        <% if (isSpouseView) { %>
        <div class="field-row field-row--half">
          <div class="field">
            <label class="field-label">PRICE PAID</label>
            <input type="text" name="price_paid" class="field-input" value="<%= firearm ? (firearm.spouse_price || '') : '' %>" placeholder="e.g. 1200">
          </div>
        </div>
        <% } else { %>
        <div class="field-row">
          <div class="field">
            <label class="field-label">PRICE PAID</label>
            <input type="text" name="price_paid" class="field-input" value="<%= firearm ? (firearm.price_paid || '') : '' %>" placeholder="e.g. 1200">
          </div>
          <div class="field">
            <label class="field-label">WHAT SPOUSE THINKS I PAID</label>
            <input type="text" name="spouse_price" class="field-input" value="<%= firearm ? (firearm.spouse_price || '') : '' %>" placeholder="e.g. 200">
          </div>
        </div>
        <% } %>
        <div class="field-row">
          <div class="field field-row--half">
            <label class="field-label">TRANSFER DATE</label>
            <input type="date" name="transfer_date" class="field-input field-input--date" value="<%= firearm ? (firearm.transfer_date || '') : '' %>">
          </div>
        </div>

        <div class="field-row field-row--half">
          <div class="field">
            <label class="field-label">FFL TRANSFERRED FROM</label>
            <input type="text" name="ffl_transferred_from" class="field-input" list="fflList" value="<%= firearm ? (firearm.ffl_transferred_from || '') : '' %>" placeholder="e.g. Dealer name, license number" autocomplete="off">
            <datalist id="fflList">
              <% fflList.forEach(f => { %><option value="<%= f %>"><% }) %>
            </datalist>
          </div>
        </div>

      </div>
    </div>

    <!-- 03: NFA (kept as marker) -->
    <%
      const nfaTypesList = ['Suppressor/Silencer','Short Barrel Rifle (SBR)','Short Barrel Shotgun (SBS)','Machine Gun','Destructive Device (DD)','Any Other Weapon (AOW)'];
      const isNfaOnLoad = firearm && nfaTypesList.includes(firearm.nfa_type);
    %>
    <div class="form-band" id="nfaBand" style="display:<%= isNfaOnLoad ? 'block' : 'none' %>">
      <div class="form-band__label">03 / NFA</div>
      <div class="form-band__fields">

        <div class="field field--checkbox">
          <label class="checkbox-label">
            <input type="checkbox" name="nfa_fmi" id="nfaFmi" value="1" class="checkbox-input"
              <%= firearm && firearm.nfa_fmi ? 'checked' : '' %>>
            <span class="checkbox-custom checkbox-custom--nfa"></span>
            <span class="checkbox-text">FMI (FIREARM MANUFACTURING INTENT)</span>
          </label>
        </div>

        <div class="field-row">
          <div class="field">
            <label class="field-label">FORM TYPE</label>
            <select name="nfa_form_type" class="field-select">
              <option value="">— SELECT —</option>
              <option value="Form 1" <%= firearm && firearm.nfa_form_type === 'Form 1' ? 'selected' : '' %>>Form 1</option>
              <option value="Form 4" <%= firearm && firearm.nfa_form_type === 'Form 4' ? 'selected' : '' %>>Form 4</option>
            </select>
          </div>
          <div class="field">
            <label class="field-label">FORM NUMBER</label>
            <input type="text" name="nfa_form_number" class="field-input mono"
              value="<%= firearm ? (firearm.nfa_form_number || '') : '' %>"
              placeholder="e.g. 20240001234">
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label class="field-label">TAX STAMP / FORM SERIAL</label>
            <input type="text" name="nfa_tax_stamp_serial" class="field-input mono"
              value="<%= firearm ? (firearm.nfa_tax_stamp_serial || '') : '' %>"
              placeholder="Tax stamp or Form serial number">
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label class="field-label">DATE SUBMITTED TO ATF</label>
            <input type="date" name="nfa_submit_date" class="field-input field-input--date"
              value="<%= firearm ? (firearm.nfa_submit_date || '') : '' %>">
          </div>
          <div class="field">
            <label class="field-label">ATF APPROVAL DATE</label>
            <input type="date" name="nfa_approve_date" class="field-input field-input--date"
              value="<%= firearm ? (firearm.nfa_approve_date || '') : '' %>">
          </div>
        </div>
        <div class="nfa-info-box">
          📋 ATF Form and Form 5320 documents can be uploaded from the item detail page after saving.
        </div>

      </div>
    </div>

    <!-- 04: DISPOSITION -->
    <div class="form-band">
      <div class="form-band__label">04 / DISPOSITION</div>
      <div class="form-band__fields">

        <div class="field field--checkbox">
          <label class="checkbox-label">
            <input type="checkbox" name="is_disposed" id="isDisposed" value="1" class="checkbox-input"
              <%= firearm && firearm.is_disposed ? 'checked' : '' %>>
            <span class="checkbox-custom checkbox-custom--warning"></span>
            <span class="checkbox-text">THIS ITEM HAS BEEN TRANSFERRED / DISPOSED OF</span>
          </label>
        </div>

        <div id="disposalFields" class="conditional-fields" style="display:<%= firearm && firearm.is_disposed ? 'block' : 'none' %>">
          <div class="field-row">
            <div class="field">
              <label class="field-label">DATE OF DISPOSAL / TRANSFER</label>
              <input type="date" name="date_disposed" class="field-input field-input--date"
                value="<%= firearm ? (firearm.date_disposed || '') : '' %>">
            </div>
            <div class="field">
              <label class="field-label">METHOD / TRANSFEREE</label>
              <input type="text" name="disposal_method" class="field-input"
                value="<%= firearm ? (firearm.disposal_method || '') : '' %>"
                placeholder="e.g. Private sale to John Doe, FFL transfer, Trade-in">
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- 05: NOTES -->
    <div class="form-band">
      <div class="form-band__label">05 / NOTES</div>
      <div class="form-band__fields">
        <div class="field-row field-row--half">
          <div class="field">
            <label class="field-label">ROUND COUNT</label>
            <input type="number" name="round_count" class="field-input mono" min="0" step="1"
              value="<%= firearm ? (firearm.round_count || 0) : 0 %>"
              placeholder="0">
          </div>
        </div>
        <div class="field">
          <label class="field-label">GENERAL NOTES</label>
          <textarea name="notes" class="field-textarea" rows="5"
            placeholder="Condition, modifications, storage location, purchase details, provenance…"><%= firearm ? (firearm.notes || '') : '' %></textarea>
        </div>
      </div>
    </div>

    <!-- 06: PHOTOS (new items only) -->
    <% if (!firearm) { %>
    <div class="form-band">
      <div class="form-band__label">06 / PHOTOS</div>
      <div class="form-band__fields">
        <input type="file" name="photos" multiple accept="image/*" id="photoInput" style="display:none">
        <div class="file-drop-zone" id="photoDropZone">
          <div class="file-drop-label">
            <span class="file-drop-icon">⊕</span>
            <span>DRAG &amp; DROP OR CLICK TO SELECT</span>
            <span class="file-drop-hint">JPG, PNG, WEBP, GIF — MAX 20MB EACH — FIRST IMAGE WILL BE PRIMARY</span>
          </div>
        </div>
        <div class="file-list" id="fileList"></div>
      </div>
    </div>
    <% } %>

    <div class="form-actions">
      <a href="<%= firearm ? '/inventory/' + firearm.id : '/inventory' %>" class="btn btn--ghost">CANCEL</a>
      <button type="submit" class="btn btn--primary"><%= firearm ? 'SAVE CHANGES' : 'ADD TO INVENTORY' %></button>
    </div>
  </form>
</div>

<script nonce="<%= cspNonce %>">
<%
function safeJSON(val) {
  return JSON.stringify(val)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026');
}
%>
const initialOpticsTags = <%- safeJSON(initialOpticsTags) %>;
const NFA_TYPES = new Set(['Suppressor/Silencer','Short Barrel Rifle (SBR)','Short Barrel Shotgun (SBS)','Machine Gun','Destructive Device (DD)','Any Other Weapon (AOW)']);
const OVERALL_LENGTH_TYPES = new Set(['Short Barrel Rifle (SBR)','Short Barrel Shotgun (SBS)']);

function onItemTypeChange(val) {
  document.getElementById('nfaBand').style.display = NFA_TYPES.has(val) ? 'block' : 'none';
  document.getElementById('barrelLengthLabel').textContent = val === 'Suppressor/Silencer' ? 'LENGTH' : 'BARREL LENGTH';
  document.getElementById('overallLengthRow').style.display = OVERALL_LENGTH_TYPES.has(val) ? '' : 'none';
}

function on3dPrintedChange(checked) {
  // label stays MANUFACTURER regardless
}

function toggleSection(id, show) {
  document.getElementById(id).style.display = show ? 'block' : 'none';
}

// ── Inline handler replacements ───────────────────────────
document.addEventListener('DOMContentLoaded', function() {
  var form = document.querySelector('.firearm-form');
  if (form) {
    form.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA' && e.target.type !== 'submit') {
        e.preventDefault();
      }
    });
  }
  var is3dPrinted = document.getElementById('is3dPrinted');
  if (is3dPrinted) is3dPrinted.addEventListener('change', function() { on3dPrintedChange(this.checked); });
  var itemType = document.getElementById('itemType');
  if (itemType) itemType.addEventListener('change', function() { onItemTypeChange(this.value); });
  var isDisposed = document.getElementById('isDisposed');
  if (isDisposed) isDisposed.addEventListener('change', function() { toggleSection('disposalFields', this.checked); });
});

// ── Optics tag input ──────────────────────────────────────
(function() {
  const container = document.getElementById('opticsTagContainer');
  const textInput = document.getElementById('opticsTagInput');
  const hidden    = document.getElementById('opticsHidden');
  if (!container) return;

  let tags = initialOpticsTags.slice();

  function renderTags() {
    container.querySelectorAll('.tag-chip').forEach(el => el.remove());
    tags.forEach((tag, i) => {
      const chip = document.createElement('span');
      chip.className = 'tag-chip';
      chip.innerHTML = '<span>' + tag.replace(/</g,'&lt;') + '</span>';
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'tag-chip__remove';
      btn.innerHTML = '&times;';
      btn.addEventListener('click', () => { tags.splice(i, 1); renderTags(); });
      chip.appendChild(btn);
      container.insertBefore(chip, textInput);
    });
    hidden.value = JSON.stringify(tags);
  }

  function addTag(val) {
    const trimmed = val.trim();
    if (trimmed && !tags.includes(trimmed)) {
      tags.push(trimmed);
      renderTags();
    }
    textInput.value = '';
  }

  textInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === 'Tab' || e.key === ',') {
      e.preventDefault();
      addTag(this.value);
    } else if (e.key === 'Backspace' && this.value === '' && tags.length) {
      tags.pop();
      renderTags();
    }
  });

  textInput.addEventListener('blur', function() {
    if (this.value.trim()) addTag(this.value);
  });

  container.addEventListener('click', () => textInput.focus());

  renderTags();
})();

// photo drop zone wired up by main.js
</script>
<%- include('partials/footer') %>
