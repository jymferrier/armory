<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <div>
      <p class="breadcrumb"><a href="/inventory">← INVENTORY</a></p>
      <h1 class="page-title"><%= firearm.manufacturer %> <span class="title-model"><%= firearm.model %></span></h1>
      <div class="detail-badges">
        <% if (firearm.is_3d_printed) { %><span class="badge badge--3dp badge--searchable" data-search="3D PRINTED">3D PRINTED</span><% } %>
        <% if (firearm.nfa_type) { %><span class="badge <%= firearm.is_nfa ? ((firearm.nfa_approve_date && (!firearm.nfa2_enabled || firearm.nfa2_approve_date)) ? 'badge--nfa-approved' : 'badge--nfa') : 'badge--type' %> badge--searchable" data-search="<%= firearm.nfa_type %>"><%= firearm.nfa_type %></span><% } %>
        <% if (firearm.caliber) { %><span class="badge badge--caliber badge--searchable" data-search="<%= firearm.caliber %>"><%= firearm.caliber %></span><% } %>
        <% if (firearm.is_disposed) { %><span class="badge badge--disposed badge--searchable" data-search="DISPOSED">DISPOSED</span><% } %>
      </div>
    </div>
    <div class="page-actions">
      <a href="/inventory/<%= firearm.id %>/edit" class="btn btn--ghost">EDIT</a>
      <form method="POST" action="/inventory/<%= firearm.id %>/delete" id="deleteFirearmForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn--danger">DELETE</button>
      </form>
    </div>
  </div>

  <% if (firearm.is_disposed) { %>
  <div class="alert alert--disposed">
    ⚠ This item has been transferred or disposed of
    <% if (firearm.date_disposed || firearm.disposal_method) { %>
      —
      <% if (firearm.date_disposed) { %><strong><%= new Date(firearm.date_disposed + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></strong><% } %>
      <% if (firearm.disposal_method) { %> &middot; <%= firearm.disposal_method %><% } %>
    <% } %>
  </div>
  <% } %>

  <div class="detail-layout">
    <!-- Left: Photos -->
    <div class="detail-photos">
      <% if (firearm.photos.length > 0) { %>
        <div class="photo-main" id="photoMain">
          <img src="/api/photo/<%= (firearm.photos.find(p=>p.is_primary) || firearm.photos[0]).filename %>" alt="Primary photo" id="photoMainImg">
        </div>
        <div class="photo-thumbs">
          <% firearm.photos.forEach(p => { %>
            <div class="photo-thumb-wrap <%= p.is_primary ? 'photo-thumb-wrap--active' : '' %>">
              <img src="/api/photo/<%= p.filename %>" class="photo-thumb" alt="">
              <div class="photo-thumb-actions">
                <% if (!p.is_primary) { %>
                  <form method="POST" action="/inventory/<%= firearm.id %>/photos/<%= p.id %>/primary">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="thumb-btn thumb-btn--primary" title="Set as primary">★</button>
                  </form>
                <% } else { %>
                  <span class="thumb-primary-badge">★</span>
                <% } %>
                <form method="POST" action="/inventory/<%= firearm.id %>/photos/<%= p.id %>/delete" class="photo-delete-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="thumb-btn thumb-btn--delete" title="Delete">✕</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="photo-placeholder">NO PHOTOS</div>
      <% } %>

      <div class="upload-section">
        <h3 class="section-title">ADD PHOTOS</h3>
        <form method="POST" action="/inventory/<%= firearm.id %>/photos" enctype="multipart/form-data">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="file" name="photos" multiple accept="image/*" id="photoInput" style="display:none">
          <div class="file-drop-zone" id="photoDropZone">
            <div class="file-drop-label">
              <span class="file-drop-icon">⊕</span>
              <span>DRAG &amp; DROP OR CLICK TO SELECT</span>
              <span class="file-drop-hint">JPG, PNG, WEBP, GIF — MAX 20MB EACH</span>
            </div>
          </div>
          <div class="file-list" id="fileList"></div>
          <button type="submit" class="btn btn--primary btn--full mt-sm">UPLOAD PHOTOS</button>
        </form>
      </div>
    </div>

    <!-- Right: Details -->
    <div class="detail-info">

      <!-- Identification -->
      <h3 class="section-title">IDENTIFICATION</h3>
      <div class="info-grid">
        <div class="info-item">
          <span class="info-label">MANUFACTURER</span>
          <span class="info-value"><%= firearm.manufacturer %></span>
        </div>
        <div class="info-item">
          <span class="info-label">MODEL</span>
          <span class="info-value"><%= firearm.model %></span>
        </div>
        <% if (firearm.model_number) { %>
        <div class="info-item">
          <span class="info-label">MODEL NUMBER</span>
          <span class="info-value mono"><%= firearm.model_number %></span>
        </div>
        <% } %>
        <% if (firearm.caliber) { %>
        <div class="info-item">
          <span class="info-label">CALIBER</span>
          <span class="info-value"><%= firearm.caliber %></span>
        </div>
        <% } %>
        <% if (firearm.serial) { %>
        <div class="info-item">
          <span class="info-label">SERIAL NUMBER</span>
          <span class="info-value mono"><%= firearm.serial %></span>
        </div>
        <% } %>
        <% if (firearm.barrel_length) { %>
        <div class="info-item">
          <span class="info-label"><%= firearm.nfa_type === 'Suppressor/Silencer' ? 'LENGTH' : 'BARREL LENGTH' %></span>
          <span class="info-value"><%= firearm.barrel_length %></span>
        </div>
        <% } %>
        <% if (firearm.overall_length) { %>
        <div class="info-item">
          <span class="info-label">OVERALL LENGTH</span>
          <span class="info-value"><%= firearm.overall_length %></span>
        </div>
        <% } %>
        <% if (firearm.optics) {
          let opticsList = [];
          try { const p = JSON.parse(firearm.optics); opticsList = Array.isArray(p) ? p : [firearm.optics]; }
          catch(e) { opticsList = [firearm.optics]; }
        %>
        <div class="info-item">
          <span class="info-label">OPTICS / ACCESSORIES</span>
          <div class="tag-list">
            <% opticsList.forEach(tag => { %><span class="tag badge--searchable" data-search="<%= tag %>"><%= tag %></span><% }) %>
          </div>
        </div>
        <% } %>
        <% if (firearm.nfa_type) { %>
        <div class="info-item">
          <span class="info-label">ITEM TYPE</span>
          <span class="info-value <%= firearm.is_nfa ? 'value--nfa' : '' %>"><%= firearm.nfa_type %></span>
        </div>
        <% } %>
        <% if (firearm.nfa_trust_name) { %>
        <div class="info-item">
          <span class="info-label">TRUST / ENTITY</span>
          <span class="info-value"><%= firearm.nfa_trust_name %></span>
        </div>
        <% } %>
      </div>

      <!-- Acquisition -->
      <% const showAcquisition = !!(firearm.date_acquired || firearm.acquired_from || firearm.transfer_date || firearm.ffl_transferred_from || (isSpouseView ? (firearm.spouse_price || firearm.price_paid) : firearm.price_paid)); %>
      <% if (showAcquisition) { %>
      <h3 class="section-title mt-lg">ACQUISITION</h3>
      <div class="info-grid">
        <% if (firearm.date_acquired) { %>
        <div class="info-item">
          <span class="info-label">ACQUIRED DATE</span>
          <span class="info-value"><%= new Date(firearm.date_acquired + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></span>
        </div>
        <% } %>
        <% if (firearm.acquired_from) { %>
        <div class="info-item">
          <span class="info-label">ACQUIRED FROM</span>
          <span class="info-value"><%= firearm.acquired_from %></span>
        </div>
        <% } %>
        <% if (isSpouseView) { %>
          <% const displayPrice = firearm.spouse_price || firearm.price_paid; %>
          <% if (displayPrice) { %>
          <div class="info-item">
            <span class="info-label">PRICE PAID</span>
            <span class="info-value">$<%= parseFloat(displayPrice).toLocaleString('en-US', {minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
          </div>
          <% } %>
        <% } else { %>
          <% if (firearm.price_paid) { %>
          <div class="info-item">
            <span class="info-label">PRICE PAID</span>
            <span class="info-value">$<%= parseFloat(firearm.price_paid).toLocaleString('en-US', {minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
          </div>
          <% } %>
          <% if (firearm.spouse_price) { %>
          <div class="info-item">
            <span class="info-label">WHAT SPOUSE THINKS I PAID</span>
            <span class="info-value">$<%= parseFloat(firearm.spouse_price).toLocaleString('en-US', {minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
          </div>
          <% } %>
        <% } %>
        <% if (firearm.transfer_date) { %>
        <div class="info-item">
          <span class="info-label">TRANSFER DATE</span>
          <span class="info-value"><%= new Date(firearm.transfer_date + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></span>
        </div>
        <% } %>
        <% if (firearm.ffl_transferred_from) { %>
        <div class="info-item">
          <span class="info-label">FFL TRANSFERRED FROM</span>
          <span class="info-value"><%= firearm.ffl_transferred_from %></span>
        </div>
        <% } %>
      </div>
      <% } %>

      <!-- NFA Details -->
      <% if (firearm.is_nfa) { %>
      <h3 class="section-title mt-lg">NFA DETAILS</h3>

      <%
        // Wait time calculation
        const submitDate = firearm.nfa_submit_date ? new Date(firearm.nfa_submit_date + 'T00:00:00') : null;
        const approveDate = firearm.nfa_approve_date ? new Date(firearm.nfa_approve_date + 'T00:00:00') : null;
        const today = new Date();
        today.setHours(0,0,0,0);
        let waitDays = null;
        let waitPending = false;
        if (submitDate) {
          const endDate = approveDate || today;
          waitDays = Math.round((endDate - submitDate) / (1000 * 60 * 60 * 24));
          waitPending = !approveDate;
        }
      %>

      <% if (submitDate) { %>
      <div class="nfa-wait-tracker <%= waitPending ? 'nfa-wait-tracker--pending' : 'nfa-wait-tracker--approved' %>">
        <div class="nfa-wait-icon"><%= waitPending ? '⏳' : '✓' %></div>
        <div class="nfa-wait-body">
          <div class="nfa-wait-days"><%= waitDays %> <span>DAYS</span></div>
          <div class="nfa-wait-label">
            <% if (waitPending) { %>
              PENDING — submitted <%= submitDate.toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'}) %>
            <% } else { %>
              APPROVED — <%= submitDate.toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %> → <%= approveDate.toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>

      <div class="info-grid">
        <% if (firearm.nfa_fmi) { %>
        <div class="info-item">
          <span class="info-label">FMI</span>
          <span class="info-value value--nfa">YES</span>
        </div>
        <% } %>
        <% if (firearm.nfa_form_type) { %>
        <div class="info-item">
          <span class="info-label">FORM TYPE</span>
          <span class="info-value"><%= firearm.nfa_form_type %></span>
        </div>
        <% } %>
        <% if (firearm.nfa_form_number) { %>
        <div class="info-item">
          <span class="info-label">FORM NUMBER</span>
          <span class="info-value mono"><%= firearm.nfa_form_number %></span>
        </div>
        <% } %>
        <% if (firearm.nfa_submit_date) { %>
        <div class="info-item">
          <span class="info-label">DATE SUBMITTED</span>
          <span class="info-value"><%= new Date(firearm.nfa_submit_date + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></span>
        </div>
        <% } %>
        <% if (firearm.nfa_tax_stamp_serial) { %>
        <div class="info-item">
          <span class="info-label">TAX STAMP / FORM SERIAL</span>
          <span class="info-value mono"><%= firearm.nfa_tax_stamp_serial %></span>
        </div>
        <% } %>
        <% if (firearm.nfa_approve_date) { %>
        <div class="info-item">
          <span class="info-label">ATF APPROVAL DATE</span>
          <span class="info-value"><%= new Date(firearm.nfa_approve_date + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></span>
        </div>
        <% } %>
      </div>

      <% if (firearm.nfa2_enabled) { %>
      <h3 class="section-title mt-lg">SECONDARY TRANSFER</h3>
      <%
        const submit2 = firearm.nfa2_submit_date ? new Date(firearm.nfa2_submit_date + 'T00:00:00') : null;
        const approve2 = firearm.nfa2_approve_date ? new Date(firearm.nfa2_approve_date + 'T00:00:00') : null;
        let wait2Days = null, wait2Pending = false;
        if (submit2) {
          const end2 = approve2 || today;
          wait2Days = Math.round((end2 - submit2) / (1000 * 60 * 60 * 24));
          wait2Pending = !approve2;
        }
      %>
      <% if (submit2) { %>
      <div class="nfa-wait-tracker <%= wait2Pending ? 'nfa-wait-tracker--pending' : 'nfa-wait-tracker--approved' %>">
        <div class="nfa-wait-icon"><%= wait2Pending ? '⏳' : '✓' %></div>
        <div class="nfa-wait-body">
          <div class="nfa-wait-days"><%= wait2Days %> <span>DAYS</span></div>
          <div class="nfa-wait-label">
            <% if (wait2Pending) { %>
              PENDING — submitted <%= submit2.toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'}) %>
            <% } else { %>
              APPROVED — <%= submit2.toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %> → <%= approve2.toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>
      <div class="info-grid">
        <% if (firearm.nfa2_fmi) { %>
        <div class="info-item">
          <span class="info-label">FMI</span>
          <span class="info-value value--nfa">YES</span>
        </div>
        <% } %>
        <% if (firearm.nfa2_form_type) { %>
        <div class="info-item">
          <span class="info-label">FORM TYPE</span>
          <span class="info-value"><%= firearm.nfa2_form_type %></span>
        </div>
        <% } %>
        <% if (firearm.nfa2_form_number) { %>
        <div class="info-item">
          <span class="info-label">FORM NUMBER</span>
          <span class="info-value mono"><%= firearm.nfa2_form_number %></span>
        </div>
        <% } %>
        <% if (firearm.nfa2_submit_date) { %>
        <div class="info-item">
          <span class="info-label">DATE SUBMITTED</span>
          <span class="info-value"><%= new Date(firearm.nfa2_submit_date + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></span>
        </div>
        <% } %>
        <% if (firearm.nfa2_tax_stamp_serial) { %>
        <div class="info-item">
          <span class="info-label">TAX STAMP / FORM SERIAL</span>
          <span class="info-value mono"><%= firearm.nfa2_tax_stamp_serial %></span>
        </div>
        <% } %>
        <% if (firearm.nfa2_approve_date) { %>
        <div class="info-item">
          <span class="info-label">ATF APPROVAL DATE</span>
          <span class="info-value"><%= new Date(firearm.nfa2_approve_date + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></span>
        </div>
        <% } %>
      </div>
      <% } %>

      <% } %>


      <!-- Disposition -->
      <% if (firearm.is_disposed) { %>
      <h3 class="section-title mt-lg">DISPOSITION</h3>
      <div class="info-grid">
        <% if (firearm.date_disposed) { %>
        <div class="info-item">
          <span class="info-label">DATE DISPOSED</span>
          <span class="info-value"><%= new Date(firearm.date_disposed + 'T00:00:00').toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></span>
        </div>
        <% } %>
        <% if (firearm.disposal_method) { %>
        <div class="info-item">
          <span class="info-label">METHOD / TRANSFEREE</span>
          <span class="info-value"><%= firearm.disposal_method %></span>
        </div>
        <% } %>
      </div>
      <% } %>

      <!-- Round Count -->
      <div class="round-counter mt-lg">
        <h3 class="section-title">ROUND COUNT</h3>
        <div class="round-counter__display">
          <span class="round-counter__total" id="roundTotal"><%= (firearm.round_count || 0).toLocaleString() %></span>
          <span class="round-counter__label">ROUNDS FIRED</span>
        </div>
        <form method="POST" action="/inventory/<%= firearm.id %>/rounds" class="round-counter__form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="number" name="add_rounds" class="round-counter__input field-input mono"
            min="1" step="1" placeholder="Rounds to add…" autocomplete="off">
          <button type="submit" class="btn btn--primary btn--sm">+ LOG ROUNDS</button>
        </form>
      </div>

      <!-- Notes -->
      <% if (firearm.notes) { %>
      <div class="notes-block mt-lg">
        <h3 class="section-title">NOTES</h3>
        <p class="notes-text"><%= firearm.notes %></p>
      </div>
      <% } %>

      <!-- Documents -->
      <div class="documents-section">
        <h3 class="section-title">DOCUMENTS</h3>
        <% const docLabels = {atf_form: 'ATF Form', form5320: 'Form 5320', additional_docs: 'Additional Document'}; %>
        <% const groupedDocs = {}; %>
        <% firearm.documents.forEach(d => { if(!groupedDocs[d.doc_type]) groupedDocs[d.doc_type]=[]; groupedDocs[d.doc_type].push(d); }); %>

        <% if (firearm.documents.length > 0) { %>
          <div class="doc-list">
            <% Object.entries(groupedDocs).forEach(([type, docs]) => { %>
              <div class="doc-group">
                <h4 class="doc-group-title"><%= docLabels[type] || type %></h4>
                <% docs.forEach(doc => { %>
                  <div class="doc-item">
                    <a href="/api/document/<%= doc.filename %>" class="doc-link" target="_blank">
                      <span class="doc-icon">📄</span>
                      <span class="doc-name"><%= doc.original_name %></span>
                    </a>
                    <form method="POST" action="/inventory/<%= firearm.id %>/documents/<%= doc.id %>/delete" class="doc-delete-form">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="thumb-btn thumb-btn--delete">✕</button>
                    </form>
                  </div>
                <% }) %>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="no-docs">No documents uploaded</p>
        <% } %>

        <form method="POST" action="/inventory/<%= firearm.id %>/documents" enctype="multipart/form-data" class="doc-upload-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% if (firearm.is_nfa) { %>
          <div class="field">
            <label class="field-label">ATF FORM(S)</label>
            <input type="file" name="atf_form" multiple accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" class="file-input-plain">
          </div>
          <div class="field">
            <label class="field-label">FORM 5320</label>
            <input type="file" name="form5320" multiple accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" class="file-input-plain">
          </div>
          <% } %>
          <div class="field">
            <label class="field-label">ADDITIONAL DOCUMENTS</label>
            <input type="file" name="additional_docs" multiple accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" class="file-input-plain">
          </div>
          <button type="submit" class="btn btn--ghost btn--full mt-sm">UPLOAD DOCUMENTS</button>
        </form>
      </div>

      <p class="detail-meta">Added <%= new Date(firearm.created_at).toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'}) %></p>
    </div>
  </div>
</div>

<div class="lightbox" id="lightbox" role="dialog" aria-modal="true">
  <button class="lightbox__close" id="lightboxClose" aria-label="Close">✕</button>
  <button class="lightbox__arrow lightbox__arrow--prev" id="lightboxPrev" aria-label="Previous">&#8249;</button>
  <img class="lightbox__img" id="lightboxImg" src="" alt="">
  <button class="lightbox__arrow lightbox__arrow--next" id="lightboxNext" aria-label="Next">&#8250;</button>
  <div class="lightbox__counter" id="lightboxCounter"></div>
</div>

<script nonce="<%= cspNonce %>">
(function() {
  // Build ordered photo list from server data
  var photos = <%- JSON.stringify(firearm.photos.map(p => '/api/photo/' + p.filename)) %>;
  var primaryFilename = '<%= (firearm.photos.find(p=>p.is_primary) || firearm.photos[0] || {filename:''}).filename %>';
  var currentIndex = 0;

  var lightbox    = document.getElementById('lightbox');
  var lightboxImg = document.getElementById('lightboxImg');
  var counter     = document.getElementById('lightboxCounter');
  var prevBtn     = document.getElementById('lightboxPrev');
  var nextBtn     = document.getElementById('lightboxNext');

  function openLightbox(index) {
    currentIndex = index;
    lightboxImg.src = photos[currentIndex];
    counter.textContent = (currentIndex + 1) + ' / ' + photos.length;
    prevBtn.hidden = photos.length <= 1;
    nextBtn.hidden = photos.length <= 1;
    lightbox.classList.add('lightbox--open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('lightbox--open');
    document.body.style.overflow = '';
  }

  function navigate(dir) {
    currentIndex = (currentIndex + dir + photos.length) % photos.length;
    lightboxImg.src = photos[currentIndex];
    counter.textContent = (currentIndex + 1) + ' / ' + photos.length;
    // Sync main photo and active thumb
    var thumbs = document.querySelectorAll('.photo-thumb');
    if (thumbs[currentIndex]) setMainPhoto(thumbs[currentIndex].src, thumbs[currentIndex].closest('.photo-thumb-wrap'));
  }

  document.getElementById('lightboxClose').addEventListener('click', closeLightbox);
  prevBtn.addEventListener('click', function() { navigate(-1); });
  nextBtn.addEventListener('click', function() { navigate(1); });

  lightbox.addEventListener('click', function(e) {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', function(e) {
    if (!lightbox.classList.contains('lightbox--open')) return;
    if (e.key === 'Escape')      closeLightbox();
    if (e.key === 'ArrowLeft')   navigate(-1);
    if (e.key === 'ArrowRight')  navigate(1);
  });

  // Open lightbox on main photo click
  var photoMain = document.getElementById('photoMain');
  if (photoMain) {
    photoMain.addEventListener('click', function() {
      var src = document.getElementById('photoMainImg').src;
      var idx = photos.findIndex(function(p) { return src.endsWith(p.split('/').pop()); });
      openLightbox(idx >= 0 ? idx : 0);
    });
  }

  // Open lightbox on thumbnail click
  document.querySelectorAll('.photo-thumb').forEach(function(thumb, idx) {
    thumb.addEventListener('click', function(e) {
      e.stopPropagation();
      openLightbox(idx);
    });
  });

  function setMainPhoto(src, wrap) {
    document.getElementById('photoMainImg').src = src;
    document.querySelectorAll('.photo-thumb-wrap').forEach(function(w) { w.classList.remove('photo-thumb-wrap--active'); });
    if (wrap) wrap.classList.add('photo-thumb-wrap--active');
  }

  // Thumbnail strip click (set main photo without opening lightbox unless clicking main)
  var thumbsContainer = document.querySelector('.photo-thumbs');
  if (thumbsContainer) {
    thumbsContainer.addEventListener('click', function(e) {
      var thumb = e.target.closest('.photo-thumb');
      if (thumb) setMainPhoto(thumb.src, thumb.closest('.photo-thumb-wrap'));
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    var deleteFirearmForm = document.getElementById('deleteFirearmForm');
    if (deleteFirearmForm) {
      deleteFirearmForm.addEventListener('submit', function(e) {
        if (!confirm('Delete this firearm and all associated files?')) e.preventDefault();
      });
    }
    document.addEventListener('submit', function(e) {
      if (e.target.classList.contains('photo-delete-form')) {
        if (!confirm('Delete this photo?')) e.preventDefault();
      } else if (e.target.classList.contains('doc-delete-form')) {
        if (!confirm('Delete this document?')) e.preventDefault();
      }
    });
  });
})();
// photo drop zone wired up by main.js
document.addEventListener('click', function(e) {
  var badge = e.target.closest('.badge--searchable');
  if (!badge) return;
  e.preventDefault();
  e.stopImmediatePropagation();
  window.location.href = '/inventory?q=' + encodeURIComponent(badge.getAttribute('data-search'));
}, true);
</script>
