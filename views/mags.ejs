<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">MAGS</h1>
      <p class="page-sub"><%= mags.length %> ENTRY<%= mags.length !== 1 ? 'S' : '' %> &middot; <%= totalQty %> TOTAL MAG<%= totalQty !== 1 ? 'S' : '' %></p>
    </div>
    <div class="page-actions">
      <form method="GET" action="/mags" class="search-form">
        <input type="text" name="q" value="<%= q %>" placeholder="SEARCH MAGS…" class="search-input">
        <div class="type-dropdown" id="platformDropdown" style="display:none">
          <button type="button" class="type-dropdown__btn" id="platformDropdownBtn">ALL PLATFORMS ▾</button>
          <div class="type-dropdown__panel" id="platformDropdownPanel"></div>
        </div>
        <button type="submit" class="btn btn--ghost">SEARCH</button>
        <% if (q) { %><a href="/mags" class="btn btn--ghost">CLEAR</a><% } %>
      </form>
      <% if (!user.is_spouse_view) { %>
      <a href="/mags/new" class="btn btn--primary">+ ADD MAG</a>
      <% } %>
    </div>
  </div>

  <% if (mags.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">⊘</div>
      <p class="empty-text"><%= q ? 'NO RESULTS FOR "' + q + '"' : 'NO MAGS CATALOGUED' %></p>
      <% if (!q && !user.is_spouse_view) { %><a href="/mags/new" class="btn btn--primary">ADD FIRST MAG</a><% } %>
    </div>
  <% } else { %>

  <div class="inventory-list mag-list">
    <div class="mag-list-header">
      <span>PLATFORM</span>
      <span>BRAND / MODEL</span>
      <span>CALIBER</span>
      <span>CAP</span>
      <span>MATERIAL</span>
      <span>COLOR</span>
      <span class="mag-col-qty">QTY</span>
    </div>
    <% mags.forEach(m => { %>
      <a href="/mags/<%= m.id %>" class="mag-row" data-platform="<%= m.platform || '' %>">
        <span class="mag-cell mag-cell--platform"><%= m.platform || '—' %></span>
        <span class="mag-cell mag-cell--brand">
          <strong><%= m.brand %></strong><% if (m.model) { %> <span class="mag-model"><%= m.model %></span><% } %>
        </span>
        <span class="mag-cell"><%= m.caliber || '—' %></span>
        <span class="mag-cell mono"><%= m.capacity ? m.capacity + ' rd' : '—' %></span>
        <span class="mag-cell"><%= m.material || '—' %></span>
        <span class="mag-cell"><%= m.color || '—' %></span>
        <span class="mag-cell mag-cell--qty mono"><%= m.quantity || 1 %></span>
      </a>
    <% }) %>
  </div>

  <% } %>
</div>
<script nonce="<%= cspNonce %>">
(function() {
  var rows = Array.from(document.querySelectorAll('.mag-row[data-platform]'));
  if (!rows.length) return;

  var platformSet = new Set(rows.map(function(r) { return r.dataset.platform; }));
  var platforms = Array.from(platformSet).sort(function(a, b) {
    if (!a && b) return 1;
    if (a && !b) return -1;
    return a.localeCompare(b);
  });
  if (platforms.length <= 1) return;

  var dropdown = document.getElementById('platformDropdown');
  var btn      = document.getElementById('platformDropdownBtn');
  var panel    = document.getElementById('platformDropdownPanel');
  var active   = new Set();

  platforms.forEach(function(platform) {
    var label = document.createElement('label');
    label.className = 'type-option';
    var cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.className = 'type-option__cb';
    cb.value = platform;
    cb.addEventListener('change', function() {
      if (cb.checked) active.add(platform); else active.delete(platform);
      apply();
    });
    var text = document.createElement('span');
    text.className = 'type-option__label';
    text.textContent = platform || 'UNSPECIFIED';
    label.appendChild(cb);
    label.appendChild(text);
    panel.appendChild(label);
  });

  dropdown.style.display = '';

  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    var open = panel.classList.toggle('type-dropdown__panel--open');
    btn.classList.toggle('type-dropdown__btn--open', open);
  });
  document.addEventListener('click', function(e) {
    if (!dropdown.contains(e.target)) {
      panel.classList.remove('type-dropdown__panel--open');
      btn.classList.remove('type-dropdown__btn--open');
    }
  });

  function apply() {
    if (active.size === 0) {
      btn.textContent = 'ALL PLATFORMS \u25be';
      btn.classList.remove('type-dropdown__btn--active');
    } else {
      btn.textContent = active.size + ' PLATFORM' + (active.size !== 1 ? 'S' : '') + ' \u25be';
      btn.classList.add('type-dropdown__btn--active');
    }
    rows.forEach(function(row) {
      row.style.display = (active.size === 0 || active.has(row.dataset.platform)) ? '' : 'none';
    });
  }
})();
</script>
<%- include('partials/footer') %>
