<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>ARMORY</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<% if (typeof user !== 'undefined' && user) { %>
<nav class="navbar">
  <a href="/inventory" class="nav-brand">
    <span class="nav-logo">⬡</span>
    <span class="nav-title">ARMORY</span>
  </a>
  <div class="nav-links">
    <form method="GET" action="/search" class="nav-search-form">
      <input type="text" name="q" placeholder="SEARCH ALL…" class="nav-search-input" autocomplete="off">
    </form>
    <a href="/inventory" class="nav-link">INVENTORY</a>
    <a href="/optics" class="nav-link">OPTICS</a>
    <a href="/mags" class="nav-link">MAGS</a>
    <a href="/trusts" class="nav-link">TRUSTS</a>
    <% if (!user.is_spouse_view) { %>
    <a href="/inventory/new" class="nav-link nav-link--accent">+ ADD</a>
    <% } %>
    <a href="/settings" class="nav-link">SETTINGS</a>
    <span class="nav-user"><%= user.username %></span>
    <a href="/logout" class="nav-link nav-link--muted">LOGOUT</a>
  </div>
</nav>
<% } %>
