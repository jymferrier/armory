<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">TRUSTS</h1>
      <p class="page-sub"><%= trusts.length %> TRUST<%= trusts.length !== 1 ? 'S' : '' %> REGISTERED</p>
    </div>
    <div class="page-actions">
      <a href="/trusts/new" class="btn btn--primary">+ ADD TRUST</a>
    </div>
  </div>

  <% if (trusts.length === 0 && unregistered.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">⬡</div>
      <p class="empty-text">NO TRUSTS REGISTERED</p>
      <a href="/trusts/new" class="btn btn--primary">ADD FIRST TRUST</a>
    </div>
  <% } else { %>

    <% if (unregistered.length > 0) { %>
    <div class="alert alert--disposed" style="margin-bottom:1.5rem;">
      <strong><%= unregistered.length %> unregistered trust<%= unregistered.length !== 1 ? 's' : '' %> found in inventory:</strong>
      <% unregistered.forEach(name => { %>
        <a href="/trusts/new?name=<%= encodeURIComponent(name) %>" style="margin-left:1rem;text-decoration:underline;"><%= name %> →</a>
      <% }) %>
    </div>
    <% } %>

    <div class="form-band" style="margin-bottom:0;">
      <% trusts.forEach(trust => { %>
      <div style="display:grid;grid-template-columns:1fr auto;align-items:center;padding:1rem 1.5rem;border-bottom:1px solid var(--border);background:var(--bg-2);">
        <div>
          <div style="font-family:var(--font-display);font-size:1.4rem;letter-spacing:0.06em;"><%= trust.name %></div>
          <% if (trust.settlor_name) { %>
          <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--text-muted);margin-top:0.2rem;">
            <%= trust.settlor_name %><% if (trust.settlor_location) { %> · <%= trust.settlor_location %><% } %>
            <% if (trust.agreement_date) { %> · Dated <%= new Date(trust.agreement_date + 'T00:00:00').toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %><% } %>
          </div>
          <% } %>
        </div>
        <div style="display:flex;gap:0.5rem;">
          <a href="/trusts/<%= trust.id %>" class="btn btn--ghost btn--sm">MANAGE</a>
        </div>
      </div>
      <% }) %>
    </div>

  <% } %>
</div>
<%- include('partials/footer') %>
