<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <h1 class="page-title">SETTINGS</h1>
  </div>

  <% if (typeof message !== 'undefined' && message) { %>
    <div class="alert alert--<%= message.type %>"><%= message.text %></div>
  <% } %>

  <div class="settings-grid">
    <!-- Change password -->
    <div class="settings-card">
      <h2 class="section-title">CHANGE PASSWORD</h2>
      <form method="POST" action="/settings/change-password" class="settings-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field">
          <label class="field-label">CURRENT PASSWORD</label>
          <input type="password" name="current_password" class="field-input" required>
        </div>
        <div class="field">
          <label class="field-label">NEW PASSWORD</label>
          <input type="password" name="new_password" class="field-input" required minlength="8">
        </div>
        <button type="submit" class="btn btn--ghost">UPDATE PASSWORD</button>
      </form>
    </div>

    <!-- Users (admin only) -->
    <% if (!user.is_spouse_view) { %>
    <div class="settings-card">
      <h2 class="section-title">USERS</h2>
      <div class="user-list">
        <% users.forEach(u => { %>
          <div class="user-item">
            <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
              <span class="user-name"><%= u.username %></span>
              <% if (u.id === user.id) { %><span class="badge">YOU</span><% } %>
              <% if (u.is_spouse_view) { %><span class="badge" style="background:var(--accent);color:#000;">SPOUSE VIEW</span><% } %>
            </div>
            <% if (u.id !== user.id) { %>
              <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
                <form method="POST" action="/settings/set-spouse-view">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="id" value="<%= u.id %>">
                  <input type="hidden" name="is_spouse_view" value="<%= u.is_spouse_view ? '0' : '1' %>">
                  <button type="submit" class="btn btn--ghost btn--sm"><%= u.is_spouse_view ? 'REVOKE SPOUSE VIEW' : 'SET SPOUSE VIEW' %></button>
                </form>
                <form method="POST" action="/settings/delete-user" class="delete-user-form" data-username="<%= u.username %>">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="id" value="<%= u.id %>">
                  <button type="submit" class="btn btn--danger btn--sm">DELETE</button>
                </form>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>

      <div class="divider"></div>

      <h3 class="section-title">ADD USER</h3>
      <form method="POST" action="/settings/add-user" class="settings-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field">
          <label class="field-label">USERNAME</label>
          <input type="text" name="username" class="field-input" required>
        </div>
        <div class="field">
          <label class="field-label">PASSWORD</label>
          <input type="password" name="password" class="field-input" required minlength="8">
        </div>
        <button type="submit" class="btn btn--primary">CREATE USER</button>
      </form>
    </div>
    <% } %>

    <!-- Export -->
    <div class="settings-card">
      <h2 class="section-title">EXPORT INVENTORY</h2>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        CSV and JSON export records only — photos and documents not included.
      </p>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1.5rem;">
        <a href="/settings/export/csv" class="btn btn--ghost">↓ EXPORT CSV</a>
        <a href="/settings/export/json" class="btn btn--ghost">↓ EXPORT JSON</a>
      </div>
      <div class="divider"></div>
      <h3 class="section-title" style="margin-top:1.25rem;">FULL ARCHIVE EXPORT</h3>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        Downloads a ZIP file containing one folder per item with all metadata, photos, and documents included.
      </p>
      <a href="/settings/export/full" class="btn btn--primary">↓ EXPORT FULL ARCHIVE (.ZIP)</a>
    </div>

    <!-- Import (admin only) -->
    <% if (!user.is_spouse_view) { %>
    <div class="settings-card">
      <h2 class="section-title">IMPORT INVENTORY</h2>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        Import records from a CSV or JSON file. Existing records are not overwritten — all imported rows are added as new items.
      </p>
      <form method="POST" action="/settings/import?_csrf=<%= csrfToken %>" enctype="multipart/form-data" class="settings-form">
        <div class="field">
          <label class="field-label">SELECT FILE (.csv or .json)</label>
          <input type="file" name="import_file" accept=".csv,.json" class="file-input-plain" required>
        </div>
        <button type="submit" class="btn btn--primary">IMPORT</button>
      </form>

      <div class="divider" style="margin-top:1.5rem;"></div>
      <h3 class="section-title" style="margin-top:1.25rem;">FULL ARCHIVE IMPORT</h3>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        Import from a full archive ZIP. Restores all item metadata, photos, and documents. Items are added as new records — no existing items are overwritten.
      </p>
      <form method="POST" action="/settings/import/zip?_csrf=<%= csrfToken %>" enctype="multipart/form-data" class="settings-form">
        <div class="field">
          <label class="field-label">SELECT ZIP FILE</label>
          <input type="file" name="import_zip" accept=".zip" class="file-input-plain" required>
        </div>
        <button type="submit" class="btn btn--primary">↑ IMPORT FULL ARCHIVE</button>
      </form>
    </div>
    <% } %>
  </div>

  <!-- Spouse Visibility (admin only) -->
  <% if (!user.is_spouse_view) { %>
  <div style="margin-top:2px;">
    <div class="settings-card">
      <h2 class="section-title">SPOUSE VISIBILITY</h2>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        Select which inventory items are visible to spouse view accounts. Price shown to spouse view accounts will use the "What Spouse Thinks I Paid" value, falling back to actual price paid.
      </p>
      <% if (allFirearms.length === 0) { %>
        <p style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted);">No items in inventory.</p>
      <% } else { %>
        <form method="POST" action="/settings/spouse-items">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% allFirearms.forEach(f => { %>
          <label class="trust-item-row" style="display:flex;align-items:center;gap:1rem;padding:0.65rem 0.75rem;border:1px solid var(--border);margin-bottom:3px;background:var(--bg-3);cursor:pointer;">
            <input type="checkbox" name="items" value="<%= f.id %>" <%= f.spouse_visible ? 'checked' : '' %> style="width:16px;height:16px;flex-shrink:0;accent-color:var(--accent);">
            <div style="flex:1;min-width:0;">
              <div style="font-family:var(--font-display);font-size:1.1rem;letter-spacing:0.05em;"><%= f.manufacturer %> <span style="color:var(--accent)"><%= f.model %></span></div>
              <div style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-muted);margin-top:0.1rem;">
                <% if (f.nfa_type) { %><span style="color:var(--nfa-red)"><%= f.nfa_type %></span><% } %>
                <% if (f.serial) { %> · S/N: <%= f.serial %><% } %>
                <% if (f.date_acquired) { %> · Acquired: <%= f.date_acquired %><% } %>
              </div>
            </div>
          </label>
          <% }) %>
          <div style="margin-top:1.25rem;display:flex;gap:0.75rem;align-items:center;">
            <button type="submit" class="btn btn--primary">SAVE VISIBILITY</button>
          </div>
        </form>
      <% } %>
    </div>
  </div>
  <% } %>

  <!-- Danger Zone (admin only) -->
  <% if (!user.is_spouse_view) { %>
  <div style="margin-top:2px;">
    <div class="settings-card" style="border:1px solid var(--red-dim);background:rgba(192,57,43,0.04);">
      <h2 class="section-title" style="color:var(--red);">⚠ DANGER ZONE</h2>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        Permanently delete all inventory records and uploaded files. This cannot be undone.
        Type <strong style="color:var(--text);font-family:var(--font-mono);">BOATING ACCIDENT</strong> to confirm.
      </p>
      <form method="POST" action="/settings/purge" class="settings-form" id="purgeForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field">
          <label class="field-label" style="color:var(--red);">CONFIRMATION</label>
          <input type="text" name="confirm" class="field-input mono" placeholder='Type BOATING ACCIDENT to confirm' autocomplete="off">
        </div>
        <button type="submit" class="btn btn--danger">PURGE ALL INVENTORY</button>
      </form>
    </div>
  </div>
  <% } %>
</div>
<script nonce="<%= cspNonce %>">
function validatePurge(form) {
  const val = form.querySelector('input[name="confirm"]').value;
  if (val !== 'BOATING ACCIDENT') {
    alert('You must type BOATING ACCIDENT exactly to confirm.');
    return false;
  }
  return true;
}
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.delete-user-form').forEach(function(form) {
    form.addEventListener('submit', function(e) {
      var name = this.getAttribute('data-username');
      if (!confirm('Delete user ' + name + '?')) e.preventDefault();
    });
  });
  var purgeForm = document.getElementById('purgeForm');
  if (purgeForm) {
    purgeForm.addEventListener('submit', function(e) {
      if (!validatePurge(this)) e.preventDefault();
    });
  }
});
</script>
<%- include('partials/footer') %>
