<%- include('partials/header') %>
<div class="page">
  <div class="page-header">
    <h1 class="page-title">SETTINGS</h1>
  </div>

  <% if (typeof message !== 'undefined' && message) { %>
    <div class="alert alert--<%= message.type %>"><%= message.text %></div>
  <% } %>

  <div class="settings-grid">
    <!-- Change password -->
    <div class="settings-card">
      <h2 class="section-title">CHANGE PASSWORD</h2>
      <form method="POST" action="/settings/change-password" class="settings-form">
        <div class="field">
          <label class="field-label">CURRENT PASSWORD</label>
          <input type="password" name="current_password" class="field-input" required>
        </div>
        <div class="field">
          <label class="field-label">NEW PASSWORD</label>
          <input type="password" name="new_password" class="field-input" required minlength="8">
        </div>
        <button type="submit" class="btn btn--ghost">UPDATE PASSWORD</button>
      </form>
    </div>

    <!-- Users -->
    <div class="settings-card">
      <h2 class="section-title">USERS</h2>
      <div class="user-list">
        <% users.forEach(u => { %>
          <div class="user-item">
            <div>
              <span class="user-name"><%= u.username %></span>
              <% if (u.id === user.id) { %><span class="badge">YOU</span><% } %>
            </div>
            <% if (u.id !== user.id) { %>
              <form method="POST" action="/settings/delete-user" onsubmit="return confirm('Delete user <%= u.username %>?')">
                <input type="hidden" name="id" value="<%= u.id %>">
                <button type="submit" class="btn btn--danger btn--sm">DELETE</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      </div>

      <div class="divider"></div>

      <h3 class="section-title">ADD USER</h3>
      <form method="POST" action="/settings/add-user" class="settings-form">
        <div class="field">
          <label class="field-label">USERNAME</label>
          <input type="text" name="username" class="field-input" required>
        </div>
        <div class="field">
          <label class="field-label">PASSWORD</label>
          <input type="password" name="password" class="field-input" required minlength="8">
        </div>
        <button type="submit" class="btn btn--primary">CREATE USER</button>
      </form>
    </div>

    <!-- Export -->
    <div class="settings-card">
      <h2 class="section-title">EXPORT INVENTORY</h2>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        CSV and JSON export records only — photos and documents not included.
      </p>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1.5rem;">
        <a href="/settings/export/csv" class="btn btn--ghost">↓ EXPORT CSV</a>
        <a href="/settings/export/json" class="btn btn--ghost">↓ EXPORT JSON</a>
      </div>
      <div class="divider"></div>
      <h3 class="section-title" style="margin-top:1.25rem;">FULL ARCHIVE EXPORT</h3>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        Downloads a ZIP file containing one folder per item with all metadata, photos, and documents included.
      </p>
      <a href="/settings/export/full" class="btn btn--primary">↓ EXPORT FULL ARCHIVE (.ZIP)</a>
    </div>

    <!-- Import -->
    <div class="settings-card">
      <h2 class="section-title">IMPORT INVENTORY</h2>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        Import records from a CSV or JSON file. Existing records are not overwritten — all imported rows are added as new items.
      </p>
      <form method="POST" action="/settings/import" enctype="multipart/form-data" class="settings-form">
        <div class="field">
          <label class="field-label">SELECT FILE (.csv or .json)</label>
          <input type="file" name="import_file" accept=".csv,.json" class="file-input-plain" required>
        </div>
        <button type="submit" class="btn btn--primary">IMPORT</button>
      </form>
    </div>
  </div>

  <!-- Danger Zone -->
  <div style="margin-top:2px;">
    <div class="settings-card" style="border:1px solid var(--red-dim);background:rgba(192,57,43,0.04);">
      <h2 class="section-title" style="color:var(--red);">⚠ DANGER ZONE</h2>
      <p style="font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.25rem;">
        Permanently delete all inventory records and uploaded files. This cannot be undone.
        Type <strong style="color:var(--text);font-family:var(--font-mono);">PURGE</strong> to confirm.
      </p>
      <form method="POST" action="/settings/purge" class="settings-form" onsubmit="return validatePurge(this)">
        <div class="field">
          <label class="field-label" style="color:var(--red);">CONFIRMATION</label>
          <input type="text" name="confirm" class="field-input mono" placeholder='Type PURGE to confirm' autocomplete="off">
        </div>
        <button type="submit" class="btn btn--danger">PURGE ALL INVENTORY</button>
      </form>
    </div>
  </div>
</div>
<script>
function validatePurge(form) {
  const val = form.querySelector('input[name="confirm"]').value;
  if (val !== 'PURGE') {
    alert('You must type PURGE exactly to confirm.');
    return false;
  }
  return true;
}
</script>
<%- include('partials/footer') %>
